@* _AdminLayout.cshtml *@
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Admin Panel</title>

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/Profile.css" />
    <link rel="stylesheet" href="~/css/darkmode.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Overlay -->
    <div class="sidebar-overlay"></div>

    <!-- LEFT SIDEBAR -->
    <aside class="admin-sidebar">
        <div class="scroll-wrapper" style="flex:1; overflow-y:auto; scrollbar-width:none; -ms-overflow-style:none;">
            <style>
                .scroll-wrapper::-webkit-scrollbar {
                    display: none;
                }
            </style>

            <!-- Logo -->
            <div class="admin-logo-header">
                <img src="~/images/ctu-logo.png" class="admin-logo" />
                <div class="admin-logo-text">BALAMBAN CAMPUS</div>
            </div>

            <!-- Menu -->
            <nav class="admin-menu">
                <a asp-action="Dashboard" asp-controller="Admin" class="menu-link" id="dashboardBtn">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </a>
                <a asp-action="Users" asp-controller="Admin" class="menu-link">
                    <i class="bi bi-person-fill"></i> <span>Users</span>
                </a>
                <a asp-action="Registration" asp-controller="Admin" class="menu-link">
                    <i class="bi bi-building"></i> <span>Registration</span>
                </a>
                <a asp-action="Reports" asp-controller="Admin" class="menu-link">
                    <i class="bi bi-file-bar-graph-fill"></i> <span>Reports</span>
                </a>
                <hr />
            </nav>

            <!-- Logout -->
            <div class="sidebar-logout">
                <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" class="d-none">
                    @Html.AntiForgeryToken()
                </form>
                <a href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i> <span>Logout</span>
                </a>
            </div>
        </div>
    </aside>

    <!-- TOP BAR -->
    <header class="admin-topbar d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-sm btn-light d-none d-md-inline-flex me-2" id="desktopSidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <button class="btn btn-sm btn-light d-md-none me-2" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <i class="bi bi-house-fill me-2"></i>
            <span class="topbar-title">@ViewData["Title"]</span>
        </div>

        <div class="d-flex align-items-center gap-2">
            <!-- Dark Mode Toggle -->
            <div id="themeToggle" style="cursor:pointer;">
                <i class="bi bi-moon-fill fs-5" id="themeIcon"></i>
            </div>

            <!-- Notifications -->
            <div class="position-relative" id="notifBell" style="cursor:pointer;">
                <i class="bi bi-bell-fill fs-5"></i>
                <span class="notif-dot"></span>
            </div>

            <!-- Small Topbar Profile Picture -->
            <img src="/images/ctu-logo.png" id="topbarProfilePic" title="Profile Picture" />

            <!-- Profile Dropdown -->
            <div class="dropdown">
                <div class="d-flex align-items-center gap-2 dropdown-toggle" role="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer;">
                    <div class="d-flex flex-column" style="font-size:0.75rem;">
                        <strong>Administrator</strong>
                        <span>Admin</span>
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                    <li><a class="dropdown-item" href="javascript:void(0);" id="viewProfileBtn">View Profile</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();">Logout</a></li>
                </ul>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="admin-content" id="adminMainContent">
        @RenderBody()
    </main>

    <!-- PROFILE TEMPLATE - UPDATED: Added Facebook beside Email -->
    <script type="text/template" id="profileTemplate">
        <div class="container py-4">

            <!-- Profile Picture Container with Mini Camera Icon -->
            <div class="profile-pic-wrapper mb-4 position-relative" style="width:140px; height:140px;">
                <img src="/images/ctu-logo.png" id="profileImage" class="rounded-circle border border-3 border-white" style="width:140px;height:140px;object-fit:cover;">

                <!-- Full Overlay (clickable) -->
                <div class="profile-pic-overlay d-flex justify-content-center align-items-center"
                     style="position:absolute; top:0; left:0; width:100%; height:100%; border-radius:50%; background:rgba(0,0,0,0.3); opacity:0; cursor:pointer; transition:opacity 0.2s;">
                    <i class="bi bi-camera-fill text-white fs-4"></i>
                </div>

                <!-- Mini Camera Icon (clickable) -->
                <div class="change-pic-icon position-absolute d-flex justify-content-center align-items-center"
                     style="width:36px; height:36px; bottom:0; right:0; background:rgba(0,0,0,0.2); border-radius:50%; border:2px solid white; cursor:pointer;">
                    <i class="bi bi-camera-fill text-white"></i>
                </div>

                <input type="file" id="profilePicInput" accept="image/*" style="display:none;">
            </div>

            <!-- Card Container below the profile picture -->
            <div class="card shadow-sm p-4" style="max-width:1200px;">
                <div class="flex-grow-1 w-100">
                    <!-- Row 1: Full Name & Position -->
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label for="fullName" class="form-label fw-bold">Full Name</label>
                            <input type="text" id="fullName" class="form-control" value="" placeholder="Enter full name">
                        </div>
                        <div class="col-md-6">
                            <label for="position" class="form-label fw-bold">Position</label>
                            <input type="text" id="position" class="form-control" value="" placeholder="Enter position">
                        </div>
                    </div>

                    <!-- Row 2: Email & Facebook (side by side) -->
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label for="email" class="form-label fw-bold">Email</label>
                            <input type="email" id="email" class="form-control" value="" placeholder="Enter email">
                        </div>
                        <div class="col-md-6">
                            <label for="facebook" class="form-label fw-bold">Facebook</label>
                            <input type="text" id="facebook" class="form-control" value="" placeholder="Enter Facebook profile URL">
                        </div>
                    </div>

                    <!-- Row 3: Employee ID & Department -->
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label for="employeeId" class="form-label fw-bold">Employee ID</label>
                            <input type="text" id="employeeId" class="form-control" value="" placeholder="Enter employee ID">
                        </div>
                        <div class="col-md-6">
                            <label for="department" class="form-label fw-bold">Department</label>
                            <input type="text" id="department" class="form-control" value="" placeholder="Enter department">
                        </div>
                    </div>

                    <!-- Row 4: Mobile Number & Address (side by side) -->
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label for="mobileNumber" class="form-label fw-bold">Mobile Number</label>
                            <input type="text" id="mobileNumber" class="form-control" value="" placeholder="Enter mobile number">
                        </div>
                        <div class="col-md-6">
                            <label for="address" class="form-label fw-bold">Address</label>
                            <input type="text" id="address" class="form-control" value="" placeholder="Enter address">
                        </div>
                    </div>

                    <!-- Save Button -->
                    <div class="text-end">
                        <button class="btn btn-primary" id="saveProfileBtn">
                            <i class="bi bi-check-circle me-1"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>

            <!-- DOCUMENTS SECTION FOR ADMIN FILES -->
            <div class="card shadow-sm p-4 mt-4" style="max-width:1200px;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0">Admin Documents</h6>
                    <!-- Hidden file input for multiple uploads -->
                    <input type="file" id="documentUploadInput" style="display:none;" multiple>
                    <!-- Upload button -->
                    <button class="btn btn-primary" id="uploadDocumentBtn">
                        <i class="bi bi-upload me-1"></i> Upload Document
                    </button>
                </div>

                <!-- Empty list - no sample documents -->
                <ul id="documentList" class="list-group list-group-flush">
                </ul>
            </div>
        </div>
    </script>

    <!-- NOTIFICATION TEMPLATE (EMPTY - NO SAMPLE DATA) -->
    <script type="text/template" id="notifTemplate">
        <div class="container py-4">
            <h4 class="mb-4">Notification History</h4>

            <!-- Empty state message -->
            <div class="text-center text-muted py-5">
                <i class="bi bi-bell" style="font-size: 3rem;"></i>
                <p class="mt-3">No notifications yet</p>
            </div>
        </div>
    </script>

    <!-- REPORT DETAILS MODAL -->
    <div class="modal fade" id="reportModal" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title" id="reportModalLabel">Report Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <h3 class="fw-bold mb-3" id="modalStudent"></h3>
                    <hr>
                    <div style="border:1px solid #ccc; border-radius:10px; padding:15px; background:#f8f9fa;">
                        <p id="modalReport" style="font-size:1.05rem; line-height:1.5;"></p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebar = document.querySelector('.admin-sidebar');
        const desktopToggle = document.getElementById('desktopSidebarToggle');
        const mobileToggle = document.getElementById('sidebarToggle');
        const overlay = document.querySelector('.sidebar-overlay');

        if(window.innerWidth >= 768) sidebar.classList.add('expanded');

        desktopToggle?.addEventListener('click', ()=>sidebar.classList.toggle('expanded'));
        mobileToggle?.addEventListener('click', ()=>{
            sidebar.classList.toggle('expanded');
            overlay.classList.toggle('active');
        });
        overlay?.addEventListener('click', ()=>{
            sidebar.classList.remove('expanded');
            overlay.classList.remove('active');
        });

        // SPA Content Switching
        const mainContent = document.getElementById("adminMainContent");
        const viewProfileBtn = document.getElementById("viewProfileBtn");
        const topbarProfilePic = document.getElementById("topbarProfilePic");
        const originalDashboardHTML = mainContent.innerHTML;

        function openDocumentSPA(){
            mainContent.style.opacity = 0;
            setTimeout(()=>{
                const template = document.getElementById("profileTemplate").innerHTML;
                mainContent.innerHTML = template;
                document.querySelector(".topbar-title").textContent = "Admin Profile";

                // ===== Profile Picture Change Functionality =====
                const profileImage = document.getElementById("profileImage");
                const profilePicInput = document.getElementById("profilePicInput");
                const overlayIcon = document.querySelector(".profile-pic-overlay");
                const miniIcon = document.querySelector(".change-pic-icon");

                // Make both camera icons clickable
                const triggerFileInput = () => profilePicInput.click();
                overlayIcon?.addEventListener("click", triggerFileInput);
                miniIcon?.addEventListener("click", triggerFileInput);

                // Handle file selection and preview
                profilePicInput.addEventListener("change", function(e) {
                    if (e.target.files && e.target.files[0]) {
                        const reader = new FileReader();
                        reader.onload = function(evt) {
                            profileImage.src = evt.target.result;
                            topbarProfilePic.src = evt.target.result;
                        };
                        reader.readAsDataURL(e.target.files[0]);
                    }
                });

                // ===== LOAD ADMIN DATA FROM DATABASE =====
                fetch('/Admin/GetProfileData')
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('fullName').value = data.fullName || '';
                            document.getElementById('position').value = data.position || '';
                            document.getElementById('email').value = data.email || '';
                            document.getElementById('facebook').value = data.facebook || '';
                            document.getElementById('employeeId').value = data.employeeId || '';
                            document.getElementById('department').value = data.department || '';
                            document.getElementById('mobileNumber').value = data.mobileNumber || '';
                            document.getElementById('address').value = data.address || '';

                            // Update profile picture if exists
                            if (data.profilePicture) {
                                document.getElementById('profileImage').src = data.profilePicture;
                                document.getElementById('topbarProfilePic').src = data.profilePicture;
                            }
                        }
                    })
                    .catch(error => console.error('Error loading profile:', error));

                // ===== SAVE PROFILE FUNCTIONALITY =====
                const saveBtn = document.getElementById('saveProfileBtn');

                saveBtn.addEventListener('click', function() {
                    // Collect data from all fields
                    const updatedData = {
                        fullName: document.getElementById('fullName').value,
                        position: document.getElementById('position').value,
                        email: document.getElementById('email').value,
                        facebook: document.getElementById('facebook').value,
                        employeeId: document.getElementById('employeeId').value,
                        department: document.getElementById('department').value,
                        mobileNumber: document.getElementById('mobileNumber').value,
                        address: document.getElementById('address').value
                    };

                    // Send to server
                    fetch('/Admin/UpdateProfile', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(updatedData)
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert('Profile saved successfully!');
                        } else {
                            alert('Error saving profile: ' + data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error saving profile');
                    });
                });

                // ===== Document Upload Functionality =====
                const documentInput = document.getElementById("documentUploadInput");
                const uploadDocumentBtn = document.getElementById("uploadDocumentBtn");
                const documentList = document.getElementById("documentList");

                uploadDocumentBtn?.addEventListener("click", ()=> documentInput.click());

                documentInput.addEventListener("change", (e)=>{
                    if(e.target.files && e.target.files.length > 0){
                        for(const file of e.target.files){
                            const li = document.createElement("li");
                            li.className = "list-group-item d-flex justify-content-between align-items-center";
                            li.innerHTML = `
                                <span>${file.name}</span>
                                <a href="#" class="btn btn-sm btn-outline-primary">Download</a>
                            `;
                            li.querySelector("a").addEventListener("click", (evt)=>{
                                evt.preventDefault();
                                const url = URL.createObjectURL(file);
                                const a = document.createElement("a");
                                a.href = url;
                                a.download = file.name;
                                a.click();
                                URL.revokeObjectURL(url);
                            });
                            documentList.appendChild(li);
                        }
                    }
                });

                mainContent.style.opacity = 1;
            },200);
        }

        viewProfileBtn?.addEventListener("click", openDocumentSPA);

        document.getElementById("dashboardBtn")?.addEventListener("click", ()=>{
            mainContent.style.opacity = 0;
            setTimeout(()=>{
                mainContent.innerHTML = originalDashboardHTML;
                document.querySelector(".topbar-title").textContent = "Dashboard";
                mainContent.style.opacity = 1;
            },200);
        });

        // Notifications SPA
        const notifBell = document.getElementById("notifBell");
        notifBell?.addEventListener("click", function() {
            mainContent.style.opacity = 0;
            setTimeout(() => {
                mainContent.innerHTML = document.getElementById("notifTemplate").innerHTML;
                document.querySelector(".topbar-title").textContent = "Notifications";
                mainContent.style.opacity = 1;
            }, 200);
        });

        // Dark Mode
        const themeToggle = document.getElementById("themeToggle");
        const themeIcon = document.getElementById("themeIcon");
        if(localStorage.getItem("darkMode")==="true"){
            document.body.classList.add("dark-mode");
            themeIcon.classList.replace("bi-moon-fill","bi-sun-fill");
        }
        themeToggle?.addEventListener("click", ()=>{
            document.body.classList.toggle("dark-mode");
            const isDark = document.body.classList.contains("dark-mode");
            themeIcon.classList.toggle("bi-moon-fill",!isDark);
            themeIcon.classList.toggle("bi-sun-fill",isDark);
            localStorage.setItem("darkMode",isDark);
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>