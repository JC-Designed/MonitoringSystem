@* _StudentLayout.cshtml *@
@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Identity
@using MonitoringSystem.Models
@inject IHttpContextAccessor HttpContextAccessor
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@{
    var token = Xsrf.GetAndStoreTokens(Context).RequestToken;
    var user = await UserManager.GetUserAsync(User);
    var userRole = user?.Role ?? "Student";
    var userFullName = user?.FullName ?? "Student User";
    var userEmail = user?.Email ?? "";
    var userProfileImage = user?.ProfileImage ?? "/images/ctu-logo.png";
    var userMobileNumber = user?.MobileNumber ?? "";
    var userAddress = user?.Address ?? "";
    var userFacebook = user?.Facebook ?? "";
    var userCompany = user?.CompanyID?.ToString() ?? "";
    var userStudentId = user?.StudentId ?? "";
    var userProgram = user?.Program ?? "";
    var userBirthDate = user?.BirthDate?.ToString("yyyy-MM-dd") ?? "2000-01-01";
    var userContact = user?.ContactPerson ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Student Panel</title>

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/Profile.css" />
    <link rel="stylesheet" href="~/css/darkmode.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    <style>
        /* ===== FIX TOP BAR WHITE CORNER ===== */
        .admin-topbar {
            background-color: #8B0000 !important;
            padding: 12px 24px !important;
        }

            .admin-topbar .d-flex.align-items-center.gap-2 {
                background: transparent !important;
            }

            .admin-topbar .dropdown {
                background: transparent !important;
            }

            .admin-topbar .dropdown-toggle {
                background: transparent !important;
                border: none !important;
                color: white !important;
            }

                .admin-topbar .dropdown-toggle:hover {
                    background: rgba(255,255,255,0.1) !important;
                }

            .admin-topbar .d-flex.flex-column {
                background: transparent !important;
            }

            .admin-topbar strong,
            .admin-topbar span {
                color: white !important;
            }

        #topbarProfilePic {
            border: 2px solid white;
            background: transparent !important;
        }

        #themeToggle, #notifBell {
            color: white !important;
        }

        /* Toast Notification Styles */
        .toast-container {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
        }

        .toast-notification {
            min-width: 320px;
            background: white;
            border-radius: 10px;
            padding: 16px 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            display: flex;
            align-items: center;
            gap: 12px;
            transform: translateX(400px);
            opacity: 0;
            transition: all 0.3s ease;
            border-left: 4px solid #07B618;
            margin-bottom: 10px;
        }

            .toast-notification.show {
                transform: translateX(0);
                opacity: 1;
            }

            .toast-notification.success {
                border-left-color: #07B618;
            }

            .toast-notification.error {
                border-left-color: #FD0606;
            }

        .toast-icon {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .toast-notification.success .toast-icon {
            background: #07B618;
            color: white;
        }

        .toast-notification.error .toast-icon {
            background: #FD0606;
            color: white;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 14px;
        }

        .toast-message {
            font-size: 13px;
            color: #666;
        }

        .toast-close {
            cursor: pointer;
            color: #999;
            font-size: 18px;
            transition: color 0.2s;
        }

            .toast-close:hover {
                color: #333;
            }

        .dark-mode .toast-notification {
            background: #2d2d2d;
            color: #fff;
        }

        .dark-mode .toast-message {
            color: #ccc;
        }

        .dark-mode .toast-close:hover {
            color: #fff;
        }

        .hours-input {
            background-color: #e9ecef;
            border: 1px solid #ced4da;
            border-radius: 4px;
            padding: 6px 12px;
            width: 100%;
            height: 38px;
            font-size: 1rem;
            font-weight: 400;
            line-height: 1.5;
            color: #495057;
        }

        .dark-mode .hours-input {
            background-color: #2d2d2d;
            border-color: #444;
            color: #e2e8f0;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Overlay -->
    <div class="sidebar-overlay"></div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- LEFT SIDEBAR -->
    <aside class="admin-sidebar">
        <div class="scroll-wrapper" style="flex:1; overflow-y:auto; scrollbar-width:none; -ms-overflow-style:none;">
            <style>
                .scroll-wrapper::-webkit-scrollbar {
                    display: none;
                }
            </style>

            <!-- Logo -->
            <div class="admin-logo-header">
                <img src="~/images/ctu-logo.png" class="admin-logo" />
                <div class="admin-logo-text">BALAMBAN CAMPUS</div>
            </div>

            <!-- Menu -->
            <nav class="admin-menu">
                <a href="javascript:void(0);" class="menu-link" id="dashboardBtn" data-url="/Student/Dashboard" data-title="Dashboard">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </a>
                <a href="javascript:void(0);" class="menu-link" id="tasksBtn" data-url="/Student/Tasks" data-title="Tasks">
                    <i class="bi bi-clipboard-check-fill"></i> <span>Tasks</span>
                </a>
                <a href="javascript:void(0);" class="menu-link" id="reportBtn" data-url="/Student/Report" data-title="Report">
                    <i class="bi bi-file-earmark-text-fill"></i> <span>Report</span>
                </a>
                <hr />
            </nav>

            <!-- Logout -->
            <div class="sidebar-logout">
                <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" class="d-none">
                    @Html.AntiForgeryToken()
                </form>
                <a href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i> <span>Logout</span>
                </a>
            </div>
        </div>
    </aside>

    <!-- TOP BAR -->
    <header class="admin-topbar d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-sm btn-light d-none d-md-inline-flex me-2" id="desktopSidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <button class="btn btn-sm btn-light d-md-none me-2" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <i class="bi bi-person-circle me-2"></i>
            <span class="topbar-title">@ViewData["Title"]</span>
        </div>

        <div class="d-flex align-items-center gap-2">
            <!-- Dark Mode Toggle -->
            <div id="themeToggle" style="cursor:pointer;">
                <i class="bi bi-moon-fill fs-5" id="themeIcon"></i>
            </div>

            <!-- Notifications -->
            <div class="position-relative" id="notifBell" style="cursor:pointer;">
                <i class="bi bi-bell-fill fs-5"></i>
                <span class="notif-dot"></span>
            </div>

            <!-- Small Topbar Profile Picture -->
            <img src="@userProfileImage" id="topbarProfilePic" title="Profile Picture" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;" />

            <!-- Profile Dropdown -->
            <div class="dropdown">
                <div class="d-flex align-items-center gap-2 dropdown-toggle" role="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer;">
                    <div class="d-flex flex-column" style="font-size:0.75rem;">
                        <strong>@userFullName</strong>
                        <span>@userRole</span>
                    </div>
                </div>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                    <li><a class="dropdown-item" href="javascript:void(0);" id="viewProfileBtn">View Profile</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();">Logout</a></li>
                </ul>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="admin-content" id="adminMainContent">
        @RenderBody()
    </main>

    <!-- Hidden inputs -->
    <input type="hidden" id="currentUserId" value="@user?.Id" />
    <input type="hidden" id="antiForgeryToken" value="@token" />

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // ========== Global Variables ==========
            const mainContent = document.getElementById("adminMainContent");
            const viewProfileBtn = document.getElementById("viewProfileBtn");
            const topbarProfilePic = document.getElementById("topbarProfilePic");

            // Store original user data from Razor
            let currentUserData = {
                fullName: '@Html.Raw(userFullName)',
                facebook: '@Html.Raw(userFacebook)',
                company: '@Html.Raw(userCompany)',
                mobileNumber: '@Html.Raw(userMobileNumber)',
                address: '@Html.Raw(userAddress)',
                contact: '@Html.Raw(userContact)',
                studentId: '@Html.Raw(userStudentId)',
                program: '@Html.Raw(userProgram)',
                birthDate: '@userBirthDate',
                email: '@Html.Raw(userEmail)',
                profileImage: '@Html.Raw(userProfileImage)'
            };

            // Hours data for profile view
            let profileHours = {
                rendered: 0,
                remaining: 0,
                total: 0
            };

            // ========== Sidebar Functionality ==========
            const sidebar = document.querySelector('.admin-sidebar');
            const desktopToggle = document.getElementById('desktopSidebarToggle');
            const mobileToggle = document.getElementById('sidebarToggle');
            const overlay = document.querySelector('.sidebar-overlay');

            function initSidebar() {
                if (window.innerWidth >= 768) sidebar.classList.add('expanded');

                desktopToggle?.addEventListener('click', () => sidebar.classList.toggle('expanded'));
                mobileToggle?.addEventListener('click', () => {
                    sidebar.classList.toggle('expanded');
                    overlay.classList.toggle('active');
                });
                overlay?.addEventListener('click', () => {
                    sidebar.classList.remove('expanded');
                    overlay.classList.remove('active');
                });
            }

            // ========== Toast Notification Function ==========
            window.showToast = function(message, type = 'success') {
                const container = document.getElementById('toastContainer');
                const toastId = 'toast_' + Date.now();

                const icon = type === 'success' ? '✓' : '✗';
                const title = type === 'success' ? 'Success' : 'Error';

                const toastHTML = `
                    <div class="toast-notification ${type}" id="${toastId}">
                        <div class="toast-icon">${icon}</div>
                        <div class="toast-content">
                            <div class="toast-title">${title}</div>
                            <div class="toast-message">${message}</div>
                        </div>
                        <div class="toast-close" onclick="this.parentElement.remove()">×</div>
                    </div>
                `;

                container.insertAdjacentHTML('beforeend', toastHTML);

                setTimeout(() => {
                    const toast = document.getElementById(toastId);
                    if (toast) {
                        toast.classList.add('show');
                    }
                }, 10);

                setTimeout(() => {
                    const toast = document.getElementById(toastId);
                    if (toast) {
                        toast.classList.remove('show');
                        setTimeout(() => toast.remove(), 300);
                    }
                }, 3000);
            };

            // ========== Helper Functions ==========
            function escapeHtml(text) {
                if (!text) return text;
                return String(text)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            async function fetchWithToken(url, options = {}) {
                const token = document.getElementById('antiForgeryToken')?.value;

                const defaultHeaders = {
                    'RequestVerificationToken': token,
                    'X-Requested-With': 'XMLHttpRequest'
                };

                if (options.body && !(options.body instanceof FormData)) {
                    defaultHeaders['Content-Type'] = 'application/json';
                }

                const response = await fetch(url, {
                    ...options,
                    headers: {
                        ...defaultHeaders,
                        ...options.headers
                    }
                });

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                return response;
            }

            // ========== Data Fetching Functions ==========
            async function fetchFreshUserData() {
                try {
                    const response = await fetchWithToken('/Student/GetCurrentUser');
                    const data = await response.json();

                    if (data.success) {
                        return data.user;
                    }
                    return currentUserData;
                } catch (error) {
                    console.error('Error fetching user data:', error);
                    return currentUserData;
                }
            }

            async function loadProfileHours() {
                try {
                    const userResponse = await fetchWithToken('/Student/GetCurrentUser');
                    const userData = await userResponse.json();
                    const total = userData.user?.totalAllottedHours || 0;

                    const logsResponse = await fetchWithToken('/Student/GetTimeLogs');
                    let rendered = 0;

                    if (logsResponse.ok) {
                        const logs = await logsResponse.json();
                        rendered = logs
                            .filter(log => log.type === 'regular')
                            .reduce((sum, log) => sum + (log.totalHours || 0), 0);
                    }

                    return {
                        rendered: rendered,
                        remaining: total - rendered,
                        total: total
                    };
                } catch (error) {
                    console.error('Error loading profile hours:', error);
                    return { rendered: 0, remaining: 0, total: 0 };
                }
            }

            // ========== Profile Functions ==========
            function getProfileHTML(userData, hours) {
                return `
                    <div class="container py-4">
                        <div class="profile-pic-wrapper mb-4 position-relative" style="width:140px; height:140px;">
                            <img src="${userData.profileImage || '/images/ctu-logo.png'}" id="profileImage" class="rounded-circle border border-3 border-white" style="width:140px;height:140px;object-fit:cover;">
                            <div class="profile-pic-overlay d-flex justify-content-center align-items-center"
                                 style="position:absolute; top:0; left:0; width:100%; height:100%; border-radius:50%; background:rgba(0,0,0,0.3); opacity:0; cursor:pointer; transition:opacity 0.2s;">
                                <i class="bi bi-camera-fill text-white fs-4"></i>
                            </div>
                            <div class="change-pic-icon position-absolute d-flex justify-content-center align-items-center"
                                 style="width:36px; height:36px; bottom:0; right:0; background:rgba(0,0,0,0.2); border-radius:50%; border:2px solid white; cursor:pointer;">
                                <i class="bi bi-camera-fill text-white"></i>
                            </div>
                            <input type="file" id="profilePicInput" accept="image/*" style="display:none;">
                        </div>

                        <div class="d-flex justify-content-end mb-3">
                            <button class="btn" id="editProfileBtn" style="background-color: #0d6efd; color: white; border: none; padding: 8px 25px; font-weight: 500;">
                                <i class="bi bi-pencil-square me-2"></i>Edit Profile
                            </button>
                        </div>

                        <div class="card shadow-sm p-4" style="max-width:1200px;">
                            <div class="flex-grow-1 w-100">
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label for="fullName" class="form-label fw-bold">Full Name</label>
                                        <input type="text" id="fullName" class="form-control" value="${escapeHtml(userData.fullName) || ''}" readonly>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="facebook" class="form-label fw-bold">Facebook</label>
                                        <input type="text" id="facebook" class="form-control" value="${escapeHtml(userData.facebook) || ''}" readonly>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="company" class="form-label fw-bold">Company</label>
                                        <input type="text" id="company" class="form-control" value="${escapeHtml(userData.company) || ''}" readonly>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label for="mobileNumber" class="form-label fw-bold">Mobile Number</label>
                                        <input type="text" id="mobileNumber" class="form-control" value="${escapeHtml(userData.mobileNumber) || ''}" readonly>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="address" class="form-label fw-bold">Address</label>
                                        <input type="text" id="address" class="form-control" value="${escapeHtml(userData.address) || ''}" readonly>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="password" class="form-label fw-bold">Password</label>
                                        <div class="input-group">
                                            <input type="password" id="password" class="form-control" value="********" readonly />
                                            <span class="input-group-text" id="togglePassword" style="background:transparent; border-left:0; cursor:pointer;">
                                                <i class="bi bi-eye-slash"></i>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label for="contactPerson" class="form-label fw-bold">Contact Person</label>
                                        <input type="text" id="contactPerson" class="form-control" value="${escapeHtml(userData.contact) || ''}" readonly>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="studentId" class="form-label fw-bold">Student ID</label>
                                        <input type="text" id="studentId" class="form-control" value="${escapeHtml(userData.studentId) || ''}" readonly>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="program" class="form-label fw-bold">Program</label>
                                        <input type="text" id="program" class="form-control" value="${escapeHtml(userData.program) || ''}" readonly>
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Rendered Hours</label>
                                        <input type="text" class="form-control" value="${hours.rendered.toFixed(1)} hrs" readonly style="background-color: #e9ecef;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Remaining Hours</label>
                                        <input type="text" class="form-control" value="${hours.remaining.toFixed(1)} hrs" readonly style="background-color: #e9ecef;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Total Allotted</label>
                                        <input type="text" class="form-control" value="${hours.total} hrs" readonly style="background-color: #e9ecef;">
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label for="birthdate" class="form-label fw-bold">Birthdate</label>
                                        <input type="date" id="birthdate" class="form-control" value="${userData.birthDate || '2000-01-01'}" readonly>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="email" class="form-label fw-bold">Email</label>
                                        <input type="email" id="email" class="form-control" value="${escapeHtml(userData.email) || ''}" readonly>
                                    </div>
                                    <div class="col-md-4"></div>
                                </div>

                                <div class="text-end" id="saveButtonContainer" style="display: none;">
                                    <button class="btn" id="saveProfileBtn" style="background-color: #07B618; border-color: #07B618; color: white; padding: 8px 30px; font-weight: 500;">
                                        <i class="bi bi-check-circle me-2"></i>Save Changes
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }

            async function openProfileSPA() {
                mainContent.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';
                document.querySelector(".topbar-title").textContent = "Profile";

                const [freshUserData, hours] = await Promise.all([
                    fetchFreshUserData(),
                    loadProfileHours()
                ]);

                if (freshUserData) {
                    currentUserData = freshUserData;
                }

                mainContent.innerHTML = getProfileHTML(currentUserData, hours);
                initializeProfileEvents();
            }

            function initializeProfileEvents() {
                const profileImage = document.getElementById("profileImage");
                const profileOverlay = document.querySelector(".profile-pic-overlay");
                const changePicIcon = document.querySelector(".change-pic-icon");
                const profilePicInput = document.getElementById("profilePicInput");

                if (profileOverlay) {
                    profileOverlay.addEventListener("click", () => profilePicInput?.click());
                }
                if (changePicIcon) {
                    changePicIcon.addEventListener("click", () => profilePicInput?.click());
                }

                if (profilePicInput) {
                    profilePicInput.addEventListener("change", async (e) => {
                        if (e.target.files && e.target.files[0]) {
                            const formData = new FormData();
                            formData.append('profileImage', e.target.files[0]);

                            try {
                                const response = await fetchWithToken('/Student/UploadProfileImage', {
                                    method: 'POST',
                                    body: formData
                                });

                                const data = await response.json();
                                if (data.success) {
                                    const reader = new FileReader();
                                    reader.onload = function(evt) {
                                        if (profileImage) profileImage.src = evt.target.result;
                                        if (topbarProfilePic) topbarProfilePic.src = evt.target.result;
                                        currentUserData.profileImage = evt.target.result;
                                    }
                                    reader.readAsDataURL(e.target.files[0]);
                                    showToast('Profile picture updated successfully!', 'success');
                                } else {
                                    showToast(data.message || 'Failed to upload image', 'error');
                                }
                            } catch (error) {
                                console.error('Error uploading image:', error);
                                showToast('Error uploading image', 'error');
                            }
                        }
                    });
                }

                const passwordInput = document.getElementById('password');
                const togglePassword = document.getElementById('togglePassword');

                if (togglePassword && passwordInput) {
                    const newToggle = togglePassword.cloneNode(true);
                    togglePassword.parentNode.replaceChild(newToggle, togglePassword);

                    newToggle.addEventListener('click', function(e) {
                        e.preventDefault();
                        const type = passwordInput.type === 'password' ? 'text' : 'password';
                        passwordInput.type = type;

                        const icon = this.querySelector('i');
                        if (icon) {
                            if (type === 'text') {
                                icon.classList.remove('bi-eye-slash');
                                icon.classList.add('bi-eye');
                            } else {
                                icon.classList.remove('bi-eye');
                                icon.classList.add('bi-eye-slash');
                            }
                        }
                    });
                }

                const editProfileBtn = document.getElementById('editProfileBtn');
                const saveButtonContainer = document.getElementById('saveButtonContainer');

                if (editProfileBtn) {
                    editProfileBtn.addEventListener('click', function() {
                        document.querySelectorAll('#fullName, #facebook, #company, #mobileNumber, #address, #contactPerson, #studentId, #program, #birthdate, #email').forEach(input => {
                            if (input) {
                                input.removeAttribute('readonly');
                                input.classList.add('border-primary');
                            }
                        });

                        editProfileBtn.style.display = 'none';
                        if (saveButtonContainer) saveButtonContainer.style.display = 'block';
                    });
                }

                const saveProfileBtn = document.getElementById('saveProfileBtn');
                if (saveProfileBtn) {
                    saveProfileBtn.addEventListener('click', async function() {
                        saveProfileBtn.disabled = true;
                        const originalText = saveProfileBtn.innerHTML;
                        saveProfileBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

                        const updatedData = {
                            FullName: document.getElementById('fullName')?.value || '',
                            Facebook: document.getElementById('facebook')?.value || '',
                            Company: document.getElementById('company')?.value || '',
                            MobileNumber: document.getElementById('mobileNumber')?.value || '',
                            Address: document.getElementById('address')?.value || '',
                            Contact: document.getElementById('contactPerson')?.value || '',
                            StudentId: document.getElementById('studentId')?.value || '',
                            Program: document.getElementById('program')?.value || '',
                            BirthDate: document.getElementById('birthdate')?.value || '',
                            Email: document.getElementById('email')?.value || ''
                        };

                        try {
                            const response = await fetchWithToken('/Student/UpdateProfile', {
                                method: 'POST',
                                body: JSON.stringify(updatedData)
                            });

                            const data = await response.json();

                            if (data.success) {
                                showToast('Profile updated successfully!', 'success');

                                document.querySelectorAll('#fullName, #facebook, #company, #mobileNumber, #address, #contactPerson, #studentId, #program, #birthdate, #email').forEach(input => {
                                    if (input) {
                                        input.setAttribute('readonly', true);
                                        input.classList.remove('border-primary');
                                    }
                                });

                                if (saveButtonContainer) saveButtonContainer.style.display = 'none';
                                if (editProfileBtn) editProfileBtn.style.display = 'block';

                                currentUserData = {
                                    ...currentUserData,
                                    fullName: updatedData.FullName,
                                    facebook: updatedData.Facebook,
                                    company: updatedData.Company,
                                    mobileNumber: updatedData.MobileNumber,
                                    address: updatedData.Address,
                                    contact: updatedData.Contact,
                                    studentId: updatedData.StudentId,
                                    program: updatedData.Program,
                                    birthDate: updatedData.BirthDate,
                                    email: updatedData.Email
                                };

                                const nameElement = document.querySelector('.dropdown strong');
                                if (nameElement && updatedData.FullName) {
                                    nameElement.textContent = updatedData.FullName;
                                }
                            } else {
                                showToast(data.message || 'Failed to save changes', 'error');
                            }
                        } catch (error) {
                            console.error('Error saving profile:', error);
                            showToast('Error: ' + error.message, 'error');
                        } finally {
                            saveProfileBtn.disabled = false;
                            saveProfileBtn.innerHTML = originalText;
                        }
                    });
                }
            }

            // ========== FIXED: Content Loading Function with Automatic Page Loading ==========
            async function loadContent(url, title) {
                // Update browser URL without reloading
                window.history.pushState({ url: url, title: title }, title, url);

                // Show loading
                mainContent.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';
                document.querySelector(".topbar-title").textContent = title;

                try {
                    const response = await fetchWithToken(url);
                    const html = await response.text();

                    // Parse and extract main content
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');

                    // Look for main content
                    const newContent = doc.getElementById('adminMainContent') ||
                                     doc.querySelector('main') ||
                                     doc.querySelector('.container') ||
                                     doc.body;

                    if (newContent) {
                        mainContent.innerHTML = newContent.innerHTML;
                    } else {
                        mainContent.innerHTML = html;
                    }

                    // ===== EXECUTE ALL SCRIPTS PROPERLY =====
                    const scripts = mainContent.querySelectorAll('script');
                    const scriptsToExecute = [];

                    scripts.forEach(oldScript => {
                        const newScript = document.createElement('script');

                        // Copy all attributes
                        Array.from(oldScript.attributes).forEach(attr => {
                            newScript.setAttribute(attr.name, attr.value);
                        });

                        if (oldScript.src) {
                            newScript.src = oldScript.src;
                            newScript.async = false;
                        } else {
                            newScript.textContent = oldScript.textContent;
                        }

                        oldScript.parentNode.replaceChild(newScript, oldScript);
                        scriptsToExecute.push(newScript);
                    });

                    // Wait for scripts to load and execute
                    setTimeout(() => {
                        // Trigger page-specific initialization
                        if (url.includes('Dashboard')) {
                            console.log('Dashboard loaded, initializing...');
                            if (typeof window.initializeDashboard === 'function') {
                                window.initializeDashboard();
                            }
                            // Trigger any dashboard-specific events
                            document.dispatchEvent(new Event('dashboardLoaded'));
                        }

                        if (url.includes('Tasks')) {
                            console.log('Tasks page loaded, loading tasks...');
                            if (typeof window.loadTasksFromDatabase === 'function') {
                                window.loadTasksFromDatabase();
                            } else {
                                // Try to find and call the function from the page
                                setTimeout(() => {
                                    if (typeof window.loadTasksFromDatabase === 'function') {
                                        window.loadTasksFromDatabase();
                                    }
                                }, 50);
                            }
                        }

                        if (url.includes('OJTReport')) {
                            console.log('OJT Report loaded, loading data...');
                            if (typeof window.loadTasksFromDatabase === 'function') {
                                window.loadTasksFromDatabase();
                            }
                            if (typeof window.loadStudentInfo === 'function') {
                                window.loadStudentInfo();
                            }
                        }

                        // Dispatch custom event for any page
                        window.dispatchEvent(new CustomEvent('contentLoaded', {
                            detail: { url: url, title: title }
                        }));
                    }, 150);

                } catch (error) {
                    console.error(`Error loading ${title}:`, error);
                    mainContent.innerHTML = `<div class="alert alert-danger m-3">Error loading ${title}. Please try again.</div>`;
                }
            }

            // ========== Event Listeners ==========
            function initEventListeners() {
                // Profile button
                viewProfileBtn?.addEventListener("click", (e) => {
                    e.preventDefault();
                    openProfileSPA();
                });

                // Dashboard button
                const dashboardBtn = document.getElementById("dashboardBtn");
                if (dashboardBtn) {
                    dashboardBtn.addEventListener("click", (e) => {
                        e.preventDefault();
                        loadContent('/Student/Dashboard', 'Dashboard');
                    });
                }

                // Tasks button
                const tasksBtn = document.getElementById("tasksBtn");
                if (tasksBtn) {
                    tasksBtn.addEventListener("click", (e) => {
                        e.preventDefault();
                        loadContent('/Student/Tasks', 'Tasks');
                    });
                }

                // Report button
                const reportBtn = document.getElementById("reportBtn");
                if (reportBtn) {
                    reportBtn.addEventListener("click", (e) => {
                        e.preventDefault();
                        loadContent('/Student/Report', 'Report');
                    });
                }

                // Handle browser back/forward buttons
                window.addEventListener('popstate', (event) => {
                    if (event.state && event.state.url) {
                        loadContent(event.state.url, event.state.title);
                    }
                });

                // Notifications
                const notifBell = document.getElementById("notifBell");
                notifBell?.addEventListener("click", function() {
                    mainContent.style.opacity = 0;
                    setTimeout(() => {
                        mainContent.innerHTML = `
                            <div class="container py-4">
                                <h4 class="mb-4">Notification History</h4>
                                <div class="card shadow-sm mb-4 p-4">
                                    <p class="text-muted">No notifications yet.</p>
                                </div>
                            </div>
                        `;
                        document.querySelector(".topbar-title").textContent = "Notifications";
                        mainContent.style.opacity = 1;
                    }, 200);
                });
            }

            // ========== Dark Mode ==========
            function initDarkMode() {
                const themeToggle = document.getElementById("themeToggle");
                const themeIcon = document.getElementById("themeIcon");

                if (localStorage.getItem("darkMode") === "true") {
                    document.body.classList.add("dark-mode");
                    themeIcon?.classList.replace("bi-moon-fill", "bi-sun-fill");
                }

                themeToggle?.addEventListener("click", () => {
                    document.body.classList.toggle("dark-mode");
                    const isDark = document.body.classList.contains("dark-mode");
                    if (themeIcon) {
                        themeIcon.classList.toggle("bi-moon-fill", !isDark);
                        themeIcon.classList.toggle("bi-sun-fill", isDark);
                    }
                    localStorage.setItem("darkMode", isDark);
                });
            }

            // ========== Initialize Everything ==========
            function init() {
                initSidebar();
                initDarkMode();
                initEventListeners();
            }

            // Run initialization when DOM is ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>