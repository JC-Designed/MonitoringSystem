@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid my-4">

    <!-- Year Dropdown (only 2026) -->
    <div class="row mb-4">
        <div class="col-12 d-flex align-items-center">
            <label for="yearSelector" class="me-3 fw-bold">Select Year:</label>
            <select id="yearSelector" class="form-select" style="width:150px;">
                <option value="2026" selected>2026</option>
            </select>
        </div>
    </div>

    <!-- ===== CHARTS SECTION ===== -->
    <div class="row g-4 mb-4">
        <!-- Pending Users vs Reports Submitted -->
        <div class="col-12">
            <div class="card shadow-sm p-4">
                <h5 class="fw-bold mb-3" id="pendingTaskTitle"></h5>
                <div style="height:380px;">
                    <canvas id="pendingTaskChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Total Users vs Total Companies (Light Green & Gold) -->
        <div class="col-12">
            <div class="card shadow-sm p-4">
                <h5 class="fw-bold mb-3" id="totalUsersCompaniesTitle"></h5>
                <div style="height:380px;">
                    <canvas id="totalUsersCompaniesChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== PROGRAM HOURS MANAGEMENT SECTION ===== -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-clock me-2 text-primary"></i>Program Hours Configuration
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Configure required OJT hours for each program. Students will automatically receive these hours based on their program.</p>

                    <!-- Program Hours Form -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle" id="programHoursTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Program (Full Name)</th>
                                            <th>Program Code</th>
                                            <th>Required Hours</th>
                                            <th>Actions</th>
                                    </thead>
                                    <tbody id="programHoursBody">
                                        <!-- Will be populated from database -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Add New Program Form -->
                    <div class="row mt-3">
                        <div class="col-md-4">
                            <input type="text" class="form-control" id="newProgramFullName" placeholder="Full name (e.g., Bachelor of Industrial Technology)">
                        </div>
                        <div class="col-md-2">
                            <input type="text" class="form-control" id="newProgramCode" placeholder="Code (e.g., BIT)">
                        </div>
                        <div class="col-md-2">
                            <input type="number" class="form-control" id="newProgramHours" placeholder="Hours" min="1" step="1">
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-success w-100" onclick="addNewProgram()">
                                <i class="fas fa-plus"></i> Add
                            </button>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary w-100" onclick="saveProgramHours()">
                                <i class="fas fa-save"></i> Save
                            </button>
                        </div>
                    </div>

                    <div class="alert alert-info mt-3 mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> Changes to program hours will automatically update the total allotted hours for all students in that program.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== DOCUMENTS MANAGEMENT SECTION ===== -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-cloud-upload-alt me-2 text-primary"></i>Document Management
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Upload Form -->
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <div class="upload-area" id="uploadArea" onclick="document.getElementById('fileInput').click()">
                                <i class="fas fa-cloud-upload-alt fa-3x mb-3 text-primary"></i>
                                <h6>Drag & Drop files here or click to browse</h6>
                                <p class="text-muted small">Supported files: PDF, DOCX, XLSX, JPG, PNG (Max size: 10MB)</p>
                                <input type="file" id="fileInput" style="display: none;" multiple onchange="handleFileSelect(this.files)">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="upload-info-card">
                                <h6 class="fw-bold mb-3">Upload Information</h6>
                                <p class="small mb-2"><i class="fas fa-info-circle me-2 text-info"></i>Files uploaded here will be visible to all students</p>
                                <p class="small mb-2"><i class="fas fa-clock me-2 text-warning"></i>Students can download files immediately</p>
                                <p class="small mb-0"><i class="fas fa-trash me-2 text-danger"></i>You can delete files anytime</p>
                            </div>
                        </div>
                    </div>

                    <!-- Files List -->
                    <div class="files-list">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0"><i class="fas fa-files me-2"></i>Uploaded Documents</h6>
                            <span class="badge bg-primary" id="totalFilesCount">0 files</span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" id="documentsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>File Name</th>
                                        <th>Type</th>
                                        <th>Size</th>
                                        <th>Uploaded</th>
                                        <th>Actions</th>
                                </thead>
                                <tbody id="documentsTableBody">
                                    <!-- Will be populated from database -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <span id="deleteFileName"></span>?</p>
                <p class="text-danger small">This action cannot be undone. Students will no longer have access to this file.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Program Confirmation Modal -->
<div class="modal fade" id="deleteProgramModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete Program</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteProgramDisplayName"></strong>?</p>
                <p class="text-warning small">This will affect all students in this program. Their total allotted hours will be set to 0 until reassigned.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteProgramBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ========== CHART CODE ==========
        Chart.defaults.font.family = 'Segoe UI';
        Chart.defaults.color = '#666';

        const premiumBarStyle = {
            borderRadius: 8,
            barPercentage: 0.8,
            categoryPercentage: 0.9,
            maxBarThickness: 50
        };

        const premiumOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'top' },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) {
                                label += ': ';
                            }
                            label += context.raw.toLocaleString();
                            return label;
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: "rgba(0,0,0,0.05)" },
                    title: {
                        display: true,
                        text: 'Number of Submissions',
                        font: { weight: 'bold' }
                    }
                },
                x: {
                    grid: { display: false },
                    title: {
                        display: true,
                        text: 'Month',
                        font: { weight: 'bold' }
                    }
                }
            }
        };

        let pendingTaskChart, totalUsersCompaniesChart;

        function createCharts() {
            const ctx1 = document.getElementById('pendingTaskChart').getContext('2d');
            const ctx2 = document.getElementById('totalUsersCompaniesChart').getContext('2d');

            pendingTaskChart = new Chart(ctx1, {
                type: 'bar',
                data: {
                    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
                    datasets: [
                        {
                            label: 'Pending Users',
                            data: [],
                            backgroundColor: '#FA90D3',
                            ...premiumBarStyle,
                            borderRadius: 8,
                            borderSkipped: false
                        },
                        {
                            label: 'Reports Submitted',
                            data: [],
                            backgroundColor: '#55D2FF',
                            ...premiumBarStyle,
                            borderRadius: 8,
                            borderSkipped: false
                        }
                    ]
                },
                options: premiumOptions
            });

            totalUsersCompaniesChart = new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
                    datasets: [
                        {
                            label: 'Total Users',
                            data: [],
                            backgroundColor: '#90FAD5',
                            ...premiumBarStyle,
                            borderRadius: 8,
                            borderSkipped: false
                        },
                        {
                            label: 'Total Companies',
                            data: [],
                            backgroundColor: '#FFC355',
                            ...premiumBarStyle,
                            borderRadius: 8,
                            borderSkipped: false
                        }
                    ]
                },
                options: premiumOptions
            });
        }

        // ========== CHART DATA LOADING ==========
        async function loadDashboardData(year) {
            try {
                document.body.style.cursor = 'wait';
                const response = await fetch(`/Admin/GetDashboardData?year=${year}`);
                if (!response.ok) throw new Error('Failed to fetch data');

                const data = await response.json();

                pendingTaskChart.data.datasets[0].data = data.pendingUsers || [];
                pendingTaskChart.data.datasets[1].data = data.reportsSubmitted || [];
                pendingTaskChart.update();

                totalUsersCompaniesChart.data.datasets[0].data = data.totalUsers || [];
                totalUsersCompaniesChart.data.datasets[1].data = data.totalCompanies || [];
                totalUsersCompaniesChart.update();

                document.getElementById('pendingTaskTitle').textContent = `${year} Dashboard - Pending Users vs Reports Submitted`;
                document.getElementById('totalUsersCompaniesTitle').textContent = `${year} Total Users vs Total Companies`;

            } catch (error) {
                console.error('Error loading dashboard data:', error);
                showNotification('Failed to load chart data', 'error');
            } finally {
                document.body.style.cursor = 'default';
            }
        }

        // ========== PROGRAM HOURS MANAGEMENT ==========

        // Program hours configuration
        let programHours = [];

        // Load program hours from server - NO AUTO-CREATION
        async function loadProgramHours() {
            try {
                const response = await fetch('/Admin/GetProgramHours');
                if (response.ok) {
                    programHours = await response.json();
                } else {
                    programHours = []; // Empty array - no default programs
                }
                renderProgramHoursTable();
            } catch (error) {
                console.error('Error loading program hours:', error);
                programHours = []; // Empty array on error
                renderProgramHoursTable();
            }
        }

        // Save program hours to server
        async function saveProgramHours() {
            // Validate all programs have required fields
            let isValid = true;
            let errorMessage = '';

            programHours.forEach(program => {
                if (!program.fullName || program.fullName.trim() === '') {
                    isValid = false;
                    errorMessage = 'Program full name cannot be empty';
                }
                if (!program.code || program.code.trim() === '') {
                    isValid = false;
                    errorMessage = 'Program code cannot be empty';
                }
                if (!program.hours || program.hours <= 0) {
                    isValid = false;
                    errorMessage = 'All programs must have valid hours (greater than 0)';
                }
            });

            if (!isValid) {
                alert(errorMessage);
                return;
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/Admin/SaveProgramHours', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(programHours)
                });

                if (response.ok) {
                    showNotification('Program hours saved successfully!', 'success');
                    await loadProgramHours(); // Reload to get updated data
                } else {
                    const error = await response.text();
                    showNotification('Failed to save: ' + error, 'error');
                }
            } catch (error) {
                console.error('Error saving program hours:', error);
                showNotification('Error saving program hours', 'error');
            }
        }

        // Render program hours table
        function renderProgramHoursTable() {
            const tbody = document.getElementById('programHoursBody');
            if (!tbody) return;

            tbody.innerHTML = '';

            if (!programHours || programHours.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">No programs configured yet. Add your first program above.</td></tr>';
                return;
            }

            programHours.sort((a, b) => a.code.localeCompare(b.code)).forEach(program => {
                const displayName = `${program.fullName} (${program.code})`;
                const row = `
                    <tr data-id="${program.id}">
                        <td>
                            <input type="text" class="form-control program-fullname" value="${escapeHtml(program.fullName)}" placeholder="Full program name">
                        </td>
                        <td>
                            <input type="text" class="form-control program-code" value="${escapeHtml(program.code)}" placeholder="Code" style="width: 100px;">
                        </td>
                        <td>
                            <input type="number" class="form-control program-hours" value="${program.hours}" min="1" step="1" style="width: 100px;">
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger delete-program-btn">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
                tbody.innerHTML += row;
            });

            // Add event listeners to the newly created rows
            attachProgramEventListeners();
        }

        // Attach event listeners to program rows
        function attachProgramEventListeners() {
            // Update program when inputs change
            document.querySelectorAll('.program-fullname').forEach((input, index) => {
                input.addEventListener('change', function() {
                    const row = this.closest('tr');
                    const id = parseInt(row.dataset.id);
                    const program = programHours.find(p => p.id === id);
                    if (program) {
                        program.fullName = this.value;
                    }
                });
            });

            document.querySelectorAll('.program-code').forEach((input, index) => {
                input.addEventListener('change', function() {
                    const row = this.closest('tr');
                    const id = parseInt(row.dataset.id);
                    const program = programHours.find(p => p.id === id);
                    if (program) {
                        program.code = this.value.toUpperCase();
                    }
                });
            });

            document.querySelectorAll('.program-hours').forEach((input, index) => {
                input.addEventListener('change', function() {
                    const row = this.closest('tr');
                    const id = parseInt(row.dataset.id);
                    const program = programHours.find(p => p.id === id);
                    if (program) {
                        program.hours = parseInt(this.value) || 0;
                    }
                });
            });

            // Delete program buttons
            document.querySelectorAll('.delete-program-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const row = this.closest('tr');
                    const id = parseInt(row.dataset.id);
                    const program = programHours.find(p => p.id === id);
                    if (program) {
                        showDeleteProgramModal(id, program.fullName, program.code);
                    }
                });
            });
        }

        // Add new program
        async function addNewProgram() {
            const fullNameInput = document.getElementById('newProgramFullName');
            const codeInput = document.getElementById('newProgramCode');
            const hoursInput = document.getElementById('newProgramHours');

            const fullName = fullNameInput.value.trim();
            const code = codeInput.value.trim().toUpperCase();
            const hours = parseInt(hoursInput.value);

            if (!fullName) {
                alert('Please enter the full program name');
                return;
            }

            if (!code) {
                alert('Please enter a program code');
                return;
            }

            if (!hours || hours <= 0) {
                alert('Please enter valid hours (greater than 0)');
                return;
            }

            // Check if program code already exists
            const exists = programHours.some(p => p.code === code);
            if (exists) {
                alert('A program with this code already exists');
                return;
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/Admin/AddProgram', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        fullName: fullName,
                        code: code,
                        hours: hours
                    })
                });

                if (response.ok) {
                    const newProgram = await response.json();
                    programHours.push(newProgram);

                    // Clear inputs
                    fullNameInput.value = '';
                    codeInput.value = '';
                    hoursInput.value = '';

                    renderProgramHoursTable();
                    showNotification('Program added successfully!', 'success');
                } else {
                    const error = await response.text();
                    showNotification('Failed to add program: ' + error, 'error');
                }
            } catch (error) {
                console.error('Error adding program:', error);
                showNotification('Error adding program', 'error');
            }
        }

        // Delete program
        let programToDelete = null;

        function showDeleteProgramModal(id, fullName, code) {
            programToDelete = { id, fullName, code };
            document.getElementById('deleteProgramDisplayName').textContent = `${fullName} (${code})`;
            new bootstrap.Modal(document.getElementById('deleteProgramModal')).show();
        }

        document.getElementById('confirmDeleteProgramBtn').addEventListener('click', async function() {
            if (programToDelete) {
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const response = await fetch(`/Admin/DeleteProgram/${programToDelete.id}`, {
                        method: 'DELETE',
                        headers: {
                            'RequestVerificationToken': token
                        }
                    });

                    if (response.ok) {
                        const index = programHours.findIndex(p => p.id === programToDelete.id);
                        if (index !== -1) {
                            programHours.splice(index, 1);
                            renderProgramHoursTable();
                            showNotification(`Program "${programToDelete.fullName} (${programToDelete.code})" deleted successfully`, 'success');
                        }
                    } else {
                        showNotification('Failed to delete program', 'error');
                    }
                } catch (error) {
                    console.error('Error deleting program:', error);
                    showNotification('Error deleting program', 'error');
                } finally {
                    bootstrap.Modal.getInstance(document.getElementById('deleteProgramModal')).hide();
                    programToDelete = null;
                }
            }
        });

        // ========== DOCUMENTS MANAGEMENT ==========

        // Documents array
        let documents = [];

        // Load documents from server
        async function loadDocuments() {
            try {
                const response = await fetch('/Admin/GetDocuments');
                if (response.ok) {
                    documents = await response.json();
                } else {
                    documents = [];
                }
                renderDocumentsTable();
            } catch (error) {
                console.error('Error loading documents:', error);
                documents = [];
                renderDocumentsTable();
            }
        }

        // Format file size
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // ========== UPDATED: Handle file selection with server upload ==========
        async function handleFileSelect(files) {
            for (let i = 0; i < files.length; i++) {
                const file = files[i];

                // Validate file size (10MB max)
                if (file.size > 10 * 1024 * 1024) {
                    alert(`File ${file.name} exceeds 10MB limit`);
                    continue;
                }

                // Get file extension
                const extension = file.name.split('.').pop().toUpperCase();
                const fileTypes = ['PDF', 'DOCX', 'XLSX', 'JPG', 'PNG'];

                if (!fileTypes.includes(extension)) {
                    alert(`File type ${extension} not supported`);
                    continue;
                }

                // Create form data for upload
                const formData = new FormData();
                formData.append('file', file);

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const response = await fetch('/Admin/UploadDocument', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': token
                        }
                    });

                    if (response.ok) {
                        const newDoc = await response.json();
                        documents.unshift(newDoc);
                        renderDocumentsTable();
                        showNotification(`File "${file.name}" uploaded successfully`, 'success');
                    } else {
                        const error = await response.text();
                        showNotification(`Failed to upload: ${error}`, 'error');
                    }
                } catch (error) {
                    console.error('Error uploading file:', error);
                    showNotification('Error uploading file', 'error');
                }
            }
        }

        // Render documents table
        function renderDocumentsTable() {
            const tbody = document.getElementById('documentsTableBody');
            const countSpan = document.getElementById('totalFilesCount');

            if (!tbody) return;

            tbody.innerHTML = '';
            countSpan.textContent = (documents?.length || 0) + ' files';

            if (!documents || documents.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">No documents uploaded yet</td></tr>';
                return;
            }

            documents.forEach(doc => {
                // Get file icon based on type
                let fileIcon = 'fa-file';
                let iconColor = '#7f8c8d';

                switch(doc.type?.toUpperCase()) {
                    case 'PDF':
                        fileIcon = 'fa-file-pdf';
                        iconColor = '#e74c3c';
                        break;
                    case 'DOCX':
                    case 'DOC':
                        fileIcon = 'fa-file-word';
                        iconColor = '#3498db';
                        break;
                    case 'XLSX':
                    case 'XLS':
                        fileIcon = 'fa-file-excel';
                        iconColor = '#27ae60';
                        break;
                    case 'JPG':
                    case 'JPEG':
                    case 'PNG':
                    case 'GIF':
                        fileIcon = 'fa-file-image';
                        iconColor = '#f39c12';
                        break;
                }

                const row = `
                    <tr data-id="${doc.id}">
                        <td>
                            <i class="fas ${fileIcon} me-2" style="color: ${iconColor}"></i>
                            ${escapeHtml(doc.name)}
                        </td>
                        <td><span class="badge bg-secondary">${doc.type || 'Unknown'}</span></td>
                        <td>${doc.size || '0 KB'}</td>
                        <td>${doc.uploaded ? new Date(doc.uploaded).toLocaleDateString() : 'Unknown'}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1 download-document" title="Download">
                                <i class="fas fa-download"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger delete-document" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
                tbody.innerHTML += row;
            });

            // Attach document event listeners
            attachDocumentEventListeners();
        }

        // Attach document event listeners
        function attachDocumentEventListeners() {
            // Download buttons
            document.querySelectorAll('.download-document').forEach((btn, index) => {
                btn.addEventListener('click', function() {
                    const row = this.closest('tr');
                    const id = row.dataset.id;
                    downloadDocument(id);
                });
            });

            // Delete buttons
            document.querySelectorAll('.delete-document').forEach((btn, index) => {
                btn.addEventListener('click', function() {
                    const row = this.closest('tr');
                    const id = row.dataset.id;
                    const name = row.querySelector('td:first-child').textContent.trim();
                    showDeleteModal(id, name);
                });
            });
        }

        // Download document
        async function downloadDocument(id) {
            try {
                window.location.href = `/Admin/DownloadDocument/${id}`;
            } catch (error) {
                console.error('Error downloading document:', error);
                showNotification('Error downloading document', 'error');
            }
        }

        // Delete document
        let deleteDocId = null;

        function showDeleteModal(docId, fileName) {
            deleteDocId = docId;
            document.getElementById('deleteFileName').textContent = fileName;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
            if (deleteDocId) {
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const response = await fetch(`/Admin/DeleteDocument/${deleteDocId}`, {
                        method: 'DELETE',
                        headers: {
                            'RequestVerificationToken': token
                        }
                    });

                    if (response.ok) {
                        const index = documents.findIndex(d => d.id === deleteDocId);
                        if (index !== -1) {
                            const docName = documents[index].name;
                            documents.splice(index, 1);
                            renderDocumentsTable();
                            showNotification(`File "${docName}" deleted successfully`, 'success');
                        }
                    } else {
                        showNotification('Failed to delete file', 'error');
                    }
                } catch (error) {
                    console.error('Error deleting document:', error);
                    showNotification('Error deleting document', 'error');
                } finally {
                    bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                    deleteDocId = null;
                }
            }
        });

        // Show notification
        function showNotification(message, type) {
            // Create notification element
            const notification = document.createElement('div');
            notification.className = `alert alert-${type === 'error' ? 'danger' : type} alert-dismissible fade show position-fixed top-0 end-0 m-3`;
            notification.style.zIndex = '9999';
            notification.style.minWidth = '300px';
            notification.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(notification);

            setTimeout(() => {
                notification.remove();
            }, 3000);
        }

        // Helper function to escape HTML
        function escapeHtml(text) {
            if (!text) return '';
            return String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        // Drag and drop handlers
        document.getElementById('uploadArea').addEventListener('dragover', (e) => {
            e.preventDefault();
            document.getElementById('uploadArea').classList.add('drag-over');
        });

        document.getElementById('uploadArea').addEventListener('dragleave', (e) => {
            e.preventDefault();
            document.getElementById('uploadArea').classList.remove('drag-over');
        });

        document.getElementById('uploadArea').addEventListener('drop', (e) => {
            e.preventDefault();
            document.getElementById('uploadArea').classList.remove('drag-over');
            handleFileSelect(e.dataTransfer.files);
        });

        // Year selector event
        document.getElementById('yearSelector').addEventListener('change', function (e) {
            loadDashboardData(e.target.value);
        });

        // Initialize everything
        createCharts();
        loadDashboardData(document.getElementById('yearSelector').value);
        loadProgramHours();
        loadDocuments();
    </script>
}

