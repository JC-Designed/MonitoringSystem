@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid my-4">

    <!-- Year Dropdown (only 2026) -->
    <div class="row mb-4">
        <div class="col-12 d-flex align-items-center">
            <label for="yearSelector" class="me-3 fw-bold">Select Year:</label>
            <select id="yearSelector" class="form-select" style="width:150px;">
                <option value="2026" selected>2026</option>
            </select>
        </div>
    </div>

    <div class="row g-4">

        <!-- Pending Users vs Task Submitted (Pink & Blue) -->
        <div class="col-12">
            <div class="card shadow-sm p-4">
                <h5 class="fw-bold mb-3" id="pendingTaskTitle"></h5>
                <div style="height:380px;">
                    <canvas id="pendingTaskChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Total Users vs Total Companies (Light Green & Gold) -->
        <div class="col-12">
            <div class="card shadow-sm p-4">
                <h5 class="fw-bold mb-3" id="totalUsersCompaniesTitle"></h5>
                <div style="height:380px;">
                    <canvas id="totalUsersCompaniesChart"></canvas>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        Chart.defaults.font.family = 'Segoe UI';
        Chart.defaults.color = '#666';

        // Thick bar styling
        const premiumBarStyle = {
            borderRadius: 8,
            barPercentage: 0.9,
            categoryPercentage: 0.9,
            maxBarThickness: 60
        };

        const premiumOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'top' }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: "rgba(0,0,0,0.05)" }
                },
                x: { grid: { display: false } }
            }
        };

        // Chart instances
        let pendingTaskChart, totalUsersCompaniesChart;

        function createCharts() {
            const ctx1 = document.getElementById('pendingTaskChart').getContext('2d');
            const ctx2 = document.getElementById('totalUsersCompaniesChart').getContext('2d');

            // First chart: Pending Users (pink) vs Task Submitted (blue)
            pendingTaskChart = new Chart(ctx1, {
                type: 'bar',
                data: {
                    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
                    datasets: [
                        { label: 'Pending Users', data: [], backgroundColor: '#FA90D3', ...premiumBarStyle },
                        { label: 'Task Submitted', data: [], backgroundColor: '#55D2FF', ...premiumBarStyle }
                    ]
                },
                options: premiumOptions
            });

            // Second chart: Total Users (light green) vs Total Companies (gold)
            totalUsersCompaniesChart = new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
                    datasets: [
                        { label: 'Total Users', data: [], backgroundColor: '#90FAD5', ...premiumBarStyle },
                        { label: 'Total Companies', data: [], backgroundColor: '#FFC355', ...premiumBarStyle }
                    ]
                },
                options: premiumOptions
            });
        }

        // Fetch data from server
        async function loadDashboardData(year) {
            try {
                document.body.style.cursor = 'wait';

                // ✅ FIXED: Correct URL to match AdminController action
                const response = await fetch(`/Admin/GetDashboardData?year=${year}`);
                if (!response.ok) throw new Error('Failed to fetch data');

                const data = await response.json();
                // Update first chart (pending vs task)
                pendingTaskChart.data.datasets[0].data = data.pendingUsers;
                pendingTaskChart.data.datasets[1].data = data.tasksSubmitted;
                pendingTaskChart.update();

                // Update second chart (total users vs companies)
                totalUsersCompaniesChart.data.datasets[0].data = data.totalUsers;
                totalUsersCompaniesChart.data.datasets[1].data = data.totalCompanies;
                totalUsersCompaniesChart.update();

                // Update titles
                document.getElementById('pendingTaskTitle').textContent = `${year} Pending Users vs Task Submitted`;
                document.getElementById('totalUsersCompaniesTitle').textContent = `${year} Total Users vs Total Companies`;

            } catch (error) {
                console.error('Error loading dashboard data:', error);
                // Optionally show a user-friendly message
            } finally {
                document.body.style.cursor = 'default';
            }
        }

        // Year selector event
        document.getElementById('yearSelector').addEventListener('change', function (e) {
            loadDashboardData(e.target.value);
        });

        // Initialize
        createCharts();
        loadDashboardData(document.getElementById('yearSelector').value);
    </script>
}