@model List<MonitoringSystem.Models.ApplicationUser>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "USERS";
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<input type="hidden" id="__RequestVerificationToken" value="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />

<!-- Toast Container for Notifications -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
    <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill me-2"></i>
                <span id="toastMessage">Operation completed successfully!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>

    <div id="errorToast" class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <span id="errorToastMessage">An error occurred</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<div class="users-page container-fluid py-4">

    <!-- ================= USERS SECTION ================= -->
    <div id="usersSection">
        <div class="card shadow-sm rounded-4 p-4">

            <!-- HEADER + CREATE COMPANY BUTTON + EXPORT BUTTON -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Users</h5>
                <div>
                    <!-- EXPORT ALL BUTTON - Exports all users organized by program -->
                    <a href="/Admin/ExportUsersToExcel" class="btn btn-success me-2">
                        <i class="bi bi-file-excel"></i> Export Excel
                    </a>
                    <button id="showCreateCompanyForm" class="btn btn-primary">Create Company</button>
                </div>
            </div>

            <!-- FILTERS (now with Program) -->
            <div class="row g-3 mb-4 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Year</label>
                    <select id="yearFilter" class="form-select filter-box">
                        <option value="">All</option>
                        <option value="2026">2026</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Search by Name</label>
                    <input type="text" id="searchName" class="form-control filter-box" placeholder="Type..." />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Role</label>
                    <select id="roleFilter" class="form-select filter-box">
                        <option value="">All</option>
                        <option value="Student">Student</option>
                        <option value="Company">Company</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>

                <!-- Program Filter -->
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Program</label>
                    <select id="programFilter" class="form-select filter-box">
                        <option value="">All</option>
                    </select>
                </div>
            </div>

            <!-- USERS TABLE -->
            <div class="table-responsive">
                <table class="table table-hover table-borderless align-middle mb-0" id="usersTable">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        @foreach (var user in Model)
                        {
                            var role = user.Role ?? "No Role";
                            <tr data-id="@user.Id"
                                data-studentid="@user.StudentId"
                                data-fullname="@user.FullName"
                                data-email="@user.Email"
                                data-role="@role"
                                data-year="@user.Year"
                                data-mobile="@user.MobileNumber"
                                data-address="@user.Address"
                                data-companyid="@user.CompanyID"
                                data-program="@user.Program"
                                data-birthdate="@(user.BirthDate.HasValue? user.BirthDate.Value.ToString("yyyy-MM-dd") : "")"
                                data-contactperson="@user.ContactPerson"
                                data-task="Complete the monthly report and submit to manager."
                                data-learning="Learned how to summarize data and meet deadlines.">
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@role</td>
                                <td class="text-end">
                                    <div class="dropdown dropend d-inline-block">
                                        <button class="btn btn-sm btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown"></button>
                                        <ul class="dropdown-menu shadow-sm">
                                            <li><a class="dropdown-item edit-btn" href="javascript:void(0);">Edit</a></li>
                                            <li><a class="dropdown-item delete-btn" href="javascript:void(0);">Delete</a></li>
                                            <li><a class="dropdown-item make-admin-btn" href="javascript:void(0);">Make Admin</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ================= SIMPLIFIED CREATE COMPANY WRAPPER ================= -->
    <div id="createCompanyWrapper" style="display: none;">
        <div class="card shadow-sm rounded-4 p-4 mb-4">
            <h5>Create Company</h5>
            <form id="createCompanyFormPage">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Company Name</label>
                        <input type="text" class="form-control" id="companyNamePage" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" id="companyEmailPage" required>
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" id="companyPasswordPage" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mobile Number</label>
                        <input type="text" class="form-control" id="companyMobilePage">
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-12">
                        <label class="form-label">Address</label>
                        <input type="text" class="form-control" id="companyAddressPage">
                    </div>
                </div>

                <!-- Hidden fields with default values -->
                <input type="hidden" id="companyTypePage" value="Commercial">
                <input type="hidden" id="companySecIdPage" value="">
                <input type="hidden" id="companyWebsitePage" value="">
                <input type="hidden" id="companyTinPage" value="">
                <input type="hidden" id="companyDescriptionPage" value="">
            </form>
        </div>

        <div class="d-flex justify-content-end gap-2 mb-4">
            <button id="submitCreateCompany" class="btn" style="background-color: #02B508; color: #fff;">Create</button>
            <button id="cancelCreateCompany" class="btn" style="background-color: #FD0606; color: #fff;">Cancel</button>
        </div>
    </div>

    <!-- ================= EDIT STUDENT WRAPPER ================= -->
    <div id="editStudentWrapper" style="display: none; margin-top:20px;">
        <div class="d-flex align-items-start mb-3">
            <div class="position-relative" style="width:140px; height:140px;">
                <img id="editStudentProfilePic" src="/images/defaultpicture.jpg" alt="Profile"
                     class="rounded-circle border border-3" style="width:100%; height:100%; object-fit:cover;">
                <div class="profile-pic-overlay d-flex justify-content-center align-items-center"
                     style="position:absolute;top:0;left:0;width:100%;height:100%;border-radius:50%;background:rgba(0,0,0,0.3);opacity:0;cursor:pointer;transition:opacity 0.2s;">
                    <i class="bi bi-camera-fill text-white fs-4"></i>
                </div>
                <div class="change-pic-icon position-absolute d-flex justify-content-center align-items-center"
                     style="width:36px; height:36px; bottom:5px; right:5px; background:rgba(0,0,0,0.6); border-radius:50%; border:2px solid white; cursor:pointer;">
                    <i class="bi bi-camera-fill text-white"></i>
                </div>
                <input type="file" id="editStudentPicInput" accept="image/*" style="display:none;">
            </div>
        </div>

        <div class="card shadow-sm rounded-4 p-4 position-relative">
            <h5 class="mb-3">Student Information</h5>
            <button id="topRightEditBtn" class="btn btn-primary position-absolute"
                    style="top:20px; right:20px; height:38px;">
                Edit
            </button>
            <form id="editStudentForm">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="editStudentFullName" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Facebook</label>
                        <input type="text" class="form-control" id="editStudentFacebook">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Company</label>
                        <input type="text" class="form-control" id="editStudentCompany">
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <label class="form-label">Mobile Number</label>
                        <input type="text" class="form-control" id="editStudentMobile">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Address</label>
                        <input type="text" class="form-control" id="editStudentAddress">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Program</label>
                        <input type="text" class="form-control" id="editStudentProgram">
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <label class="form-label">Contact Person</label>
                        <input type="text" class="form-control" id="editStudentContactPerson">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Student ID</label>
                        <input type="text" class="form-control" id="editStudentID">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Birthdate</label>
                        <input type="date" class="form-control" id="editStudentBirthdate">
                    </div>
                </div>

                <!-- NEW ROW: Hours Summary (read-only) -->
                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Rendered Hours</label>
                        <input type="text" class="form-control" id="editStudentRenderedHours" readonly style="background-color: #e9ecef;">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Remaining Hours</label>
                        <input type="text" class="form-control" id="editStudentRemainingHours" readonly style="background-color: #e9ecef;">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Total Allotted Hours</label>
                        <input type="text" class="form-control" id="editStudentTotalHours" readonly style="background-color: #e9ecef;">
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" id="editStudentEmail" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Role</label>
                        <input type="text" class="form-control" id="editStudentRole" readonly>
                    </div>
                    <div class="col-md-4">
                        <!-- Empty column to maintain 3-column layout -->
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- ================= REDESIGNED EDIT COMPANY WRAPPER (MATCHING COMPANY LAYOUT) ================= -->
    <div id="editCompanyWrapper" style="display:none; margin:0; padding:0;">

        <!-- FULL-WIDTH COVER PHOTO WITH CAMERA ICON -->
        <div style="position:relative; width:100%; height:240px; overflow:hidden;">
            <img id="editCompanyBanner"
                 src="/images/banner-placeholder.jpg"
                 style="width:100%; height:100%; object-fit:cover; display:block;">
            <div class="banner-camera" onclick="document.getElementById('companyBannerInput').click()">
                <i class="bi bi-camera-fill"></i> Change Cover
            </div>
            <input type="file" id="companyBannerInput" hidden accept="image/*">
        </div>

        <!-- PROFILE IMAGE OVER BANNER WITH CAMERA ICON -->
        <div class="position-relative" style="margin-top:-85px; margin-left:40px; width:170px; z-index:10;">
            <img id="editCompanyProfilePic"
                 src="/images/defaultpicture.jpg"
                 class="rounded-circle border border-4 border-white shadow"
                 style="width:170px; height:170px; object-fit:cover;">
            <div class="camera-overlay" onclick="document.getElementById('companyPicInput').click()">
                <i class="bi bi-camera-fill"></i>
            </div>
            <input type="file" id="companyPicInput" hidden accept="image/*">
        </div>

        <!-- EDIT BUTTON AT THE TOP RIGHT -->
        <div class="container mt-3">
            <div class="d-flex justify-content-end">
                <button id="editCompanyInfoBtn" class="btn" style="background-color:#0d6efd; color:white;">
                    <i class="bi bi-pencil"></i> Edit Profile
                </button>
            </div>
        </div>

        <!-- COMPANY INFORMATION CARD -->
        <div class="container mt-3">
            <h4 class="fw-bold mb-3">COMPANY INFORMATION</h4>
            <div class="card shadow-sm p-4 mb-4">
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold">Company Name</label>
                        <input type="text" id="editCompanyName" class="form-control" value="" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Contact Number</label>
                        <input type="text" id="editCompanyMobile" class="form-control" value="" readonly>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold">Address</label>
                        <input type="text" id="editCompanyAddress" class="form-control" value="" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Company ID</label>
                        <input type="text" id="editCompanyID" class="form-control" value="" readonly>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold">Industry</label>
                        <input type="text" id="editCompanyIndustry" class="form-control" value="" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Website</label>
                        <input type="text" id="editCompanyWebsite" class="form-control" value="" readonly>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-12">
                        <label class="form-label fw-bold">Description</label>
                        <textarea id="editCompanyDescription" class="form-control" rows="2" readonly></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- CONTACT PERSON CARD (Combined with User Information) -->
        <div class="container mt-4">
            <h4 class="fw-bold mb-3">CONTACT PERSON</h4>
            <div class="card shadow-sm p-4">
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold">Name</label>
                        <input type="text" id="contactPersonName" class="form-control" value="" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Email</label>
                        <input type="email" id="contactPersonEmail" class="form-control" value="" readonly>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold">Mobile Number</label>
                        <input type="text" id="contactPersonMobile" class="form-control" value="" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Role</label>
                        <input type="text" id="contactPersonRole" class="form-control" value="Company" readonly>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label class="form-label fw-bold">Department</label>
                        <input type="text" id="contactPersonDepartment" class="form-control" value="" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Facebook</label>
                        <input type="text" id="contactPersonFacebook" class="form-control" value="" readonly>
                    </div>
                </div>
            </div>
        </div>

        <!-- ADD TRAINEE BUTTON -->
        <div class="d-flex justify-content-start mt-3 mb-4" style="margin-left: 10px;">
            <button id="addTraineeBtn" class="btn" style="background-color: #2A91FF; color: #fff;">
                + Add Trainee
            </button>
        </div>

        <!-- ADD TRAINEE MODAL -->
        <div class="modal fade" id="addTraineeModal" tabindex="-1">
            <div class="modal-dialog modal-xl modal-dialog-centered">
                <div class="modal-content rounded-4">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Select Trainees</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-borderless align-middle mb-0" id="modalStudentsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-center px-3">Select</th>
                                        <th class="px-3">Student Code</th>
                                        <th class="px-3">Name</th>
                                        <th class="px-3">Email</th>
                                        <th class="px-3">Program</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Rows will be populated dynamically via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="addSelectedTrainees" class="btn btn-success px-4">Add Selected</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- TRAINEES TABLE -->
        <div class="card shadow-sm rounded-4 p-4 mt-3">
            <h5 class="mb-3">Trainees</h5>
            <div class="table-responsive">
                <table class="table table-hover table-borderless align-middle mb-0" id="traineesTable">
                    <thead class="table-light">
                        <tr>
                            <th>Student ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Program</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- No example data - will be populated dynamically -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- BUTTONS BELOW THE TABLE -->
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button id="saveTraineesChanges" class="btn btn-success">Save Changes</button>
            <button id="resetTraineesPassword" class="btn btn-warning">Reset Password</button>
        </div>

        <!-- SAVE CHANGES BUTTON AT BOTTOM RIGHT -->
        <div class="container mt-4 mb-4">
            <div class="d-flex justify-content-end">
                <button id="saveCompanyChangesBtn" class="btn" style="background-color:#07B618; color:white; display:none; padding: 10px 30px;">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
            </div>
        </div>
    </div>

    <!-- Styles for camera icons -->
    <style>
        .camera-overlay {
            position: absolute;
            bottom: 10px;
            right: 10px;
            background-color: rgba(0, 0, 0, 0.6);
            color: white;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border: 2px solid white;
            transition: all 0.2s;
            z-index: 20;
        }

            .camera-overlay:hover {
                background-color: rgba(0, 0, 0, 0.8);
                transform: scale(1.1);
            }

        .banner-camera {
            position: absolute;
            bottom: 20px;
            right: 20px;
            background-color: rgba(255, 255, 255, 0.9);
            color: #333;
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 500;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
            transition: all 0.2s;
            z-index: 20;
        }

            .banner-camera:hover {
                background-color: white;
                transform: scale(1.05);
            }

            .banner-camera i {
                margin-right: 5px;
            }
    </style>

    <!-- ================= TASKS TABLE WRAPPER ================= -->
    <div id="tasksWrapper" style="display: none; margin-top:20px;">
        <div class="card shadow-sm rounded-4 p-4">
            <h5 class="mb-3">Tasks</h5>
            <div class="table-responsive">
                <table class="table table-hover table-borderless align-middle mb-0" id="tasksTable">
                    <thead class="table-light">
                        <tr>
                            <th>Task Title</th>
                            <th>Date From</th>
                            <th>Date To</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr data-task="Complete the monthly report and submit to manager."
                            data-learning="Learned how to summarize data and meet deadlines."
                            data-status="Ongoing">
                            <td>Complete Report</td>
                            <td>2026-02-01</td>
                            <td>2026-02-05</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-light view-task-btn" data-bs-toggle="modal" data-bs-target="#viewTaskModal">
                                    <i class="bi bi-eye-fill"></i>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ================= VIEW TASK MODAL ================= -->
    <div class="modal fade" id="viewTaskModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Task Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Task Title</label>
                            <input type="text" id="modalTaskTitle" class="form-control" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Status</label>
                            <select id="modalTaskStatus" class="form-select">
                                <option value="Ongoing">Ongoing</option>
                                <option value="Completed">Completed</option>
                                <option value="Aborted">Aborted</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Date From</label>
                            <input type="date" id="modalTaskFrom" class="form-control" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Date To</label>
                            <input type="date" id="modalTaskTo" class="form-control" readonly>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Task</label>
                            <textarea id="modalTaskTask" class="form-control" rows="3" readonly></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Learning</label>
                            <textarea id="modalTaskLearning" class="form-control" rows="3" readonly></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= DELETE CONFIRMATION MODAL ================= -->
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color: #8B0000; color: white; border: none;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="deleteConfirmModalLabel" style="color: white; font-size: 1.1rem;">Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="font-size: 0.8rem;"></button>
                </div>
                <div class="modal-body py-2">
                    <p class="mb-1" style="font-size: 0.95rem;">Are you sure you want to delete?</p>
                    <p class="fw-bold text-center mb-0" id="deleteUserInfo" style="color: white; word-break: break-word; font-size: 1.1rem;"></p>
                </div>
                <div class="modal-footer border-0 justify-content-center gap-2 pt-0 pb-3">
                    <button type="button" class="btn px-3 py-1 fw-bold" style="background-color: #02B508; color: white; border: none; min-width: 80px; font-size: 0.9rem;" id="confirmDeleteBtn">YES</button>
                    <button type="button" class="btn px-3 py-1 fw-bold" style="background-color: #FD0606; color: white; border: none; min-width: 80px; font-size: 0.9rem;" data-bs-dismiss="modal">NO</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= MAKE ADMIN CONFIRMATION MODAL ================= -->
    <div class="modal fade" id="makeAdminConfirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 650px;">
            <div class="modal-content" style="background-color: #8B0000; color: white; border: none; min-height: 160px;">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="font-size: 0.9rem;"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="mb-0" style="font-size: 1rem; text-align: center; line-height: 1.4; white-space: nowrap;">
                        Are you sure you want to make <strong id="makeAdminUserInfo" style="color: white; font-weight: 700;"></strong> an Administrator?
                    </p>
                </div>
                <div class="modal-footer border-0 justify-content-end gap-3 pt-0 pb-3">
                    <button type="button" class="btn px-3 py-1 fw-bold" style="background-color: #02B508; color: white; border: none; min-width: 80px; font-size: 0.9rem;" id="confirmMakeAdminBtn">YES</button>
                    <button type="button" class="btn px-3 py-1 fw-bold" style="background-color: #FD0606; color: white; border: none; min-width: 80px; font-size: 0.9rem;" data-bs-dismiss="modal">NO</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= SCRIPT ================= -->
    <script>
        // Global variables
        const tbody = document.querySelector("#usersTable tbody");
        let rowToEdit = null;
        const yearFilter = document.getElementById("yearFilter");
        const searchName = document.getElementById("searchName");
        const roleFilter = document.getElementById("roleFilter");
        const programFilter = document.getElementById("programFilter");

        const usersSection = document.getElementById("usersSection");
        const createCompanyWrapper = document.getElementById("createCompanyWrapper");
        const editStudentWrapper = document.getElementById("editStudentWrapper");
        const editCompanyWrapper = document.getElementById("editCompanyWrapper");
        const tasksWrapper = document.getElementById("tasksWrapper");
        const showCreateBtn = document.getElementById("showCreateCompanyForm");
        const profilePic = document.getElementById("editStudentProfilePic");
        const profileOverlay = document.querySelector(".profile-pic-overlay");
        const miniCamera = document.querySelector(".change-pic-icon");
        const profileInput = document.getElementById("editStudentPicInput");

        // Toast elements - will be initialized after DOM is loaded
        let successToast, errorToast, toastMessage, errorToastMessage;

        // ===== POPULATE PROGRAM FILTER =====
        function populateProgramFilter() {
            const programSet = new Set();
            [...tbody.rows].forEach(row => {
                const prog = row.dataset.program;
                if (prog && prog.trim() !== '') {
                    programSet.add(prog.trim());
                }
            });
            const sortedPrograms = Array.from(programSet).sort();
            programFilter.innerHTML = '<option value="">All</option>';
            sortedPrograms.forEach(prog => {
                const option = document.createElement('option');
                option.value = prog;
                option.textContent = prog;
                programFilter.appendChild(option);
            });
        }
        populateProgramFilter();

        // ===== FILTER TABLE =====
        function filterTable() {
            const yearVal = yearFilter.value;
            const nameVal = searchName.value.toLowerCase();
            const roleVal = roleFilter.value;
            const programVal = programFilter.value;

            [...tbody.rows].forEach(row => {
                let show = true;
                const fullName = row.dataset.fullname.toLowerCase();
                if (yearVal && row.dataset.year !== yearVal) show = false;
                if (nameVal && !fullName.includes(nameVal)) show = false;
                if (roleVal && row.dataset.role !== roleVal) show = false;
                if (programVal && row.dataset.program !== programVal) show = false;
                row.style.display = show ? "" : "none";
            });
        }
        [yearFilter, searchName, roleFilter, programFilter].forEach(el => el.addEventListener("input", filterTable));

        // ===== CLEAR ALL FILTERS FUNCTION =====
        function clearAllFilters() {
            yearFilter.value = "";
            searchName.value = "";
            roleFilter.value = "";
            programFilter.value = "";
            filterTable();
        }

        // ===== SHOW CREATE COMPANY =====
        showCreateBtn.addEventListener("click", () => {
            usersSection.style.display = "none";
            createCompanyWrapper.style.display = "block";
            editStudentWrapper.style.display = "none";
            editCompanyWrapper.style.display = "none";
            tasksWrapper.style.display = "none";
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        document.getElementById("cancelCreateCompany").addEventListener("click", () => {
            createCompanyWrapper.style.display = "none";
            usersSection.style.display = "block";
        });

        // ===== EDIT USER =====
        document.querySelectorAll(".edit-btn").forEach(btn => {
            btn.addEventListener("click", e => {
                e.preventDefault();
                rowToEdit = btn.closest("tr");
                const role = rowToEdit.dataset.role;

                usersSection.style.display = "none";
                createCompanyWrapper.style.display = "none";
                editStudentWrapper.style.display = "none";
                editCompanyWrapper.style.display = "none";
                tasksWrapper.style.display = "none";

                if(role === "Student"){
                    document.getElementById("editStudentFullName").value = rowToEdit.dataset.fullname;
                    document.getElementById("editStudentEmail").value = rowToEdit.dataset.email;
                    document.getElementById("editStudentRole").value = role;
                    document.getElementById("editStudentMobile").value = rowToEdit.dataset.mobile || "";
                    document.getElementById("editStudentAddress").value = rowToEdit.dataset.address || "";
                    document.getElementById("editStudentProgram").value = rowToEdit.dataset.program || "";
                    document.getElementById("editStudentID").value = rowToEdit.dataset.studentid || "";
                    document.getElementById("editStudentBirthdate").value = rowToEdit.dataset.birthdate || "";
                    document.getElementById("editStudentContactPerson").value = rowToEdit.dataset.contactperson || "";
                    profilePic.src = "/images/defaultpicture.jpg";

                    // Fetch hours summary for the student
                    fetch(`/Admin/GetStudentHoursSummary?userId=${rowToEdit.dataset.id}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                document.getElementById('editStudentRenderedHours').value = data.rendered.toFixed(1) + ' hrs';
                                document.getElementById('editStudentRemainingHours').value = data.remaining.toFixed(1) + ' hrs';
                                document.getElementById('editStudentTotalHours').value = data.total + ' hrs';
                            } else {
                                // Set defaults
                                document.getElementById('editStudentRenderedHours').value = '0 hrs';
                                document.getElementById('editStudentRemainingHours').value = '0 hrs';
                                document.getElementById('editStudentTotalHours').value = '0 hrs';
                            }
                        })
                        .catch(error => {
                            console.error('Error fetching hours:', error);
                            document.getElementById('editStudentRenderedHours').value = 'Error';
                            document.getElementById('editStudentRemainingHours').value = 'Error';
                            document.getElementById('editStudentTotalHours').value = 'Error';
                        });

                    editStudentWrapper.style.display = "block";
                    tasksWrapper.style.display = "block";
                } else if(role === "Company"){
                    // Load company data from database
                    fetch(`/Admin/GetCompanyDetails?userId=${rowToEdit.dataset.id}`)
                        .then(response => response.json())
                        .then(data => {
                            console.log("Company data received:", data);
                            if (data.success) {
                                // Company Information
                                document.getElementById("editCompanyName").value = data.companyName || '';
                                document.getElementById("editCompanyMobile").value = data.mobileNumber || '';
                                document.getElementById("editCompanyAddress").value = data.address || '';
                                document.getElementById("editCompanyID").value = data.companyId || '';
                                document.getElementById("editCompanyIndustry").value = data.industry || '';
                                document.getElementById("editCompanyWebsite").value = data.website || '';
                                document.getElementById("editCompanyDescription").value = data.companyDescription || '';

                                // Contact Person (Combined)
                                document.getElementById("contactPersonName").value = data.fullName || data.contactPersonName || '';
                                document.getElementById("contactPersonEmail").value = data.email || '';
                                document.getElementById("contactPersonMobile").value = data.mobileNumber || data.contactPersonMobile || '';
                                document.getElementById("contactPersonRole").value = 'Company';
                                document.getElementById("contactPersonDepartment").value = data.contactPersonPosition || '';
                                document.getElementById("contactPersonFacebook").value = data.contactPersonFacebook || '';

                                // Images
                                document.getElementById("editCompanyProfilePic").src = data.profileImage || '/images/defaultpicture.jpg';
                                document.getElementById("editCompanyBanner").src = data.bannerImage || '/images/banner-placeholder.jpg';
                            } else {
                                // Fallback to dataset values
                                document.getElementById("editCompanyName").value = rowToEdit.dataset.fullname;
                                document.getElementById("editCompanyMobile").value = rowToEdit.dataset.mobile || "";
                                document.getElementById("editCompanyAddress").value = rowToEdit.dataset.address || "";
                                document.getElementById("editCompanyID").value = rowToEdit.dataset.companyid || "";
                            }
                        })
                        .catch(error => {
                            console.error('Error loading company details:', error);
                            // Fallback to dataset values
                            document.getElementById("editCompanyName").value = rowToEdit.dataset.fullname;
                            document.getElementById("editCompanyMobile").value = rowToEdit.dataset.mobile || "";
                            document.getElementById("editCompanyAddress").value = rowToEdit.dataset.address || "";
                            document.getElementById("editCompanyID").value = rowToEdit.dataset.companyid || "";
                        });

                    editCompanyWrapper.style.display = "block";
                }

                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        });

        document.getElementById("topRightEditBtn").addEventListener("click", () => {
            const form = document.getElementById("editStudentForm");
            [...form.elements].forEach(el => {
                if(el.id !== "editStudentRole") el.removeAttribute("readonly");
            });
        });

        // ===== PROFILE PICTURE CHANGE =====
        profileOverlay.addEventListener("click", ()=> profileInput.click());
        miniCamera.addEventListener("click", ()=> profileInput.click());
        profileInput.addEventListener("change", (e)=>{
            if(e.target.files && e.target.files[0]){
                const reader = new FileReader();
                reader.onload = function(evt){ profilePic.src = evt.target.result; }
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        // ===== VIEW TASK MODAL =====
        document.querySelectorAll(".view-task-btn").forEach(btn => {
            btn.addEventListener("click", () => {
                const row = btn.closest("tr");
                document.getElementById("modalTaskTitle").value = row.cells[0].textContent;
                document.getElementById("modalTaskFrom").value = row.cells[1].textContent;
                document.getElementById("modalTaskTo").value = row.cells[2].textContent;
                document.getElementById("modalTaskTask").value = row.dataset.task || "No task provided.";
                document.getElementById("modalTaskLearning").value = row.dataset.learning || "No learning provided.";
                document.getElementById("modalTaskStatus").value = row.dataset.status || "Ongoing";
            });
        });

        // ===== COMPANY IMAGE PREVIEW =====
        document.getElementById("companyPicInput").addEventListener("change", e => {
            if (e.target.files[0]) {
                const reader = new FileReader();
                reader.onload = ev => document.getElementById("editCompanyProfilePic").src = ev.target.result;
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        document.getElementById("companyBannerInput").addEventListener("change", e => {
            if (e.target.files[0]) {
                const reader = new FileReader();
                reader.onload = ev => document.getElementById("editCompanyBanner").src = ev.target.result;
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        // ===== EDIT COMPANY BUTTON FUNCTIONALITY =====
        document.getElementById("editCompanyInfoBtn")?.addEventListener("click", function() {
            // Make all inputs editable
            const inputs = document.querySelectorAll('#editCompanyWrapper input, #editCompanyWrapper textarea');
            inputs.forEach(input => input.removeAttribute('readonly'));

            // Hide edit button, show save button
            document.getElementById("editCompanyInfoBtn").style.display = 'none';
            document.getElementById("saveCompanyChangesBtn").style.display = 'block';
        });

        // ===== SAVE COMPANY CHANGES BUTTON FUNCTIONALITY =====
        document.getElementById("saveCompanyChangesBtn")?.addEventListener("click", async function() {
            // Collect all updated data
            const updatedData = {
                companyName: document.getElementById("editCompanyName").value,
                mobileNumber: document.getElementById("editCompanyMobile").value,
                address: document.getElementById("editCompanyAddress").value,
                companyId: document.getElementById("editCompanyID").value,
                industry: document.getElementById("editCompanyIndustry").value,
                website: document.getElementById("editCompanyWebsite").value,
                companyDescription: document.getElementById("editCompanyDescription").value,
                // Contact Person fields
                fullName: document.getElementById("contactPersonName").value,
                email: document.getElementById("contactPersonEmail").value,
                contactPersonMobile: document.getElementById("contactPersonMobile").value,
                contactPersonRole: document.getElementById("contactPersonRole").value,
                contactPersonPosition: document.getElementById("contactPersonDepartment").value,
                contactPersonFacebook: document.getElementById("contactPersonFacebook").value
            };

            try {
                const token = document.getElementById('__RequestVerificationToken').value;

                const response = await fetch('/Admin/UpdateCompany', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(updatedData)
                });

                const result = await response.json();

                if (result.success) {
                    if (toastMessage) toastMessage.textContent = 'Company updated successfully!';
                    if (successToast) successToast.show();

                    // Make inputs readonly again
                    const inputs = document.querySelectorAll('#editCompanyWrapper input, #editCompanyWrapper textarea');
                    inputs.forEach(input => input.setAttribute('readonly', true));

                    // Hide save button, show edit button
                    document.getElementById("editCompanyInfoBtn").style.display = 'block';
                    document.getElementById("saveCompanyChangesBtn").style.display = 'none';
                } else {
                    if (errorToastMessage) errorToastMessage.textContent = 'Failed to update company: ' + (result.message || 'Unknown error');
                    if (errorToast) errorToast.show();
                }
            } catch (error) {
                console.error('Error updating company:', error);
                if (errorToastMessage) errorToastMessage.textContent = 'Error updating company: ' + error.message;
                if (errorToast) errorToast.show();
            }
        });

        const addTraineeBtn = document.getElementById("addTraineeBtn");
        const modalStudentsTbody = document.querySelector("#modalStudentsTable tbody");

        // Open modal and populate with student users
        addTraineeBtn.addEventListener("click", () => {
            modalStudentsTbody.innerHTML = "";

            [...tbody.rows].forEach(row => {
                if(row.dataset.role === "Student") {
                    const tr = document.createElement("tr");
                    tr.innerHTML = `
                        <td><input type="checkbox" class="select-trainee-checkbox" data-id="${row.dataset.id}" data-studentid="${row.dataset.studentid || ''}" data-fullname="${row.dataset.fullname}" data-email="${row.dataset.email}" data-program="${row.dataset.program || ''}"></td>
                        <td>${row.dataset.studentid || row.dataset.id || ''}</td>
                        <td>${row.dataset.fullname}</td>
                        <td>${row.dataset.email}</td>
                        <td>${row.dataset.program || ''}</td>
                    `;
                    modalStudentsTbody.appendChild(tr);
                }
            });

            const modal = new bootstrap.Modal(document.getElementById('addTraineeModal'));
            modal.show();
        });

        // ===== Add Selected Trainees to Trainees Table =====
        document.getElementById("addSelectedTrainees").addEventListener("click", () => {
            const checkboxes = document.querySelectorAll(".select-trainee-checkbox:checked");
            const traineesTableBody = document.querySelector("#traineesTable tbody");

            checkboxes.forEach(cb => {
                if(![...traineesTableBody.rows].some(r => r.cells[1].textContent === cb.dataset.fullname)) {
                    const tr = document.createElement("tr");
                    tr.innerHTML = `
                        <td>${cb.dataset.studentid || cb.dataset.id || ''}</td>
                        <td>${cb.dataset.fullname}</td>
                        <td>${cb.dataset.email}</td>
                        <td>${cb.dataset.program || ''}</td>
                        <td class="text-end">
                            <button class="btn btn-sm remove-trainee-btn" style="background: transparent; border: none; color: #FD0606; cursor: pointer;">Remove</button>
                        </td>
                    `;
                    traineesTableBody.appendChild(tr);
                }
            });

            const modalEl = document.getElementById('addTraineeModal');
            const modalInstance = bootstrap.Modal.getInstance(modalEl);
            modalInstance.hide();
        });

        // ===== DELETE USER MODAL FUNCTIONALITY =====
        let userToDelete = null;

        // Open delete modal when delete button is clicked
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('delete-btn')) {
                e.preventDefault();
                e.stopPropagation();

                const row = e.target.closest('tr');
                userToDelete = {
                    id: row.dataset.id,
                    fullName: row.dataset.fullname,
                    row: row
                };

                // Display user fullname in modal
                document.getElementById('deleteUserInfo').textContent = `${userToDelete.fullName}`;

                // Show the modal
                const deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
                deleteModal.show();
            }
        });

        // Handle confirm delete button
        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (!userToDelete) return;

            const token = document.getElementById('__RequestVerificationToken').value;

            fetch('/Admin/DeleteUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(userToDelete.id)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Remove the row from table
                    if (userToDelete.row) {
                        userToDelete.row.remove();
                        // Reprogram filter after deletion
                        populateProgramFilter();
                        filterTable();
                    }
                    if (toastMessage) toastMessage.textContent = 'User deleted successfully';
                    if (successToast) successToast.show();
                } else {
                    if (errorToastMessage) errorToastMessage.textContent = 'Failed to delete user: ' + (data.message || 'Unknown error');
                    if (errorToast) errorToast.show();
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (errorToastMessage) errorToastMessage.textContent = 'An error occurred while deleting';
                if (errorToast) errorToast.show();
            })
            .finally(() => {
                // Hide modal
                const deleteModal = bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal'));
                if (deleteModal) {
                    deleteModal.hide();
                }
                userToDelete = null;
            });
        });

        // ===== MAKE ADMIN MODAL FUNCTIONALITY =====
        let userToMakeAdmin = null;

        // Open make admin modal when make-admin button is clicked
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('make-admin-btn')) {
                e.preventDefault();
                e.stopPropagation();

                const row = e.target.closest('tr');
                userToMakeAdmin = {
                    id: row.dataset.id,
                    fullName: row.dataset.fullname,
                    row: row
                };

                // Display user fullname in modal
                document.getElementById('makeAdminUserInfo').textContent = `${userToMakeAdmin.fullName}`;

                // Show the modal
                const makeAdminModal = new bootstrap.Modal(document.getElementById('makeAdminConfirmModal'));
                makeAdminModal.show();
            }
        });

        // Handle confirm make admin button
        document.getElementById('confirmMakeAdminBtn').addEventListener('click', function() {
            if (!userToMakeAdmin) return;

            const token = document.getElementById('__RequestVerificationToken').value;
            const confirmBtn = this;
            const originalText = confirmBtn.textContent;

            // Disable button to prevent double submission
            confirmBtn.disabled = true;
            confirmBtn.textContent = 'Processing...';

            fetch('/Admin/MakeAdmin', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ userId: userToMakeAdmin.id })
            })
            .then(async response => {
                if (!response.ok) {
                    const contentType = response.headers.get('content-type');
                    if (contentType && contentType.includes('application/json')) {
                        const errorData = await response.json();
                        throw new Error(errorData.message || `Server error: ${response.status}`);
                    } else {
                        const errorText = await response.text();
                        throw new Error(`HTTP ${response.status}: ${errorText.substring(0, 100)}`);
                    }
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    // Update the role in the table
                    if (userToMakeAdmin.row) {
                        const roleCell = userToMakeAdmin.row.cells[2];
                        roleCell.textContent = 'Admin';
                        userToMakeAdmin.row.dataset.role = 'Admin';
                    }
                    if (toastMessage) toastMessage.textContent = 'User is now an Admin.';
                    if (successToast) successToast.show();

                    // Hide modal
                    const makeAdminModal = bootstrap.Modal.getInstance(document.getElementById('makeAdminConfirmModal'));
                    if (makeAdminModal) {
                        makeAdminModal.hide();
                    }
                } else {
                    if (errorToastMessage) errorToastMessage.textContent = 'Failed to make user Admin: ' + (data.message || 'Unknown error');
                    if (errorToast) errorToast.show();
                }
            })
            .catch(error => {
                console.error('Make Admin Error:', error);
                if (errorToastMessage) errorToastMessage.textContent = 'An error occurred. ' + error.message;
                if (errorToast) errorToast.show();
            })
            .finally(() => {
                confirmBtn.disabled = false;
                confirmBtn.textContent = originalText;
                userToMakeAdmin = null;
            });
        });

        // ===== FUNCTION TO ADD NEW COMPANY TO TABLE =====
        function addNewCompanyToTable(company) {
            const tbody = document.querySelector("#usersTable tbody");

            const newRow = document.createElement("tr");
            newRow.setAttribute("data-id", company.id);
            newRow.setAttribute("data-fullname", company.fullName);
            newRow.setAttribute("data-email", company.email);
            newRow.setAttribute("data-role", "Company");
            newRow.setAttribute("data-mobile", company.mobileNumber || "");
            newRow.setAttribute("data-address", company.address || "");
            newRow.setAttribute("data-companyid", company.companyId || "");
            newRow.setAttribute("data-program", "");
            newRow.setAttribute("data-birthdate", "");
            newRow.setAttribute("data-contactperson", "");

            newRow.innerHTML = `
                <td>${company.fullName}</td>
                <td>${company.email}</td>
                <td>Company</td>
                <td class="text-end">
                    <div class="dropdown dropend d-inline-block">
                        <button class="btn btn-sm btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown"></button>
                        <ul class="dropdown-menu shadow-sm">
                            <li><a class="dropdown-item edit-btn" href="javascript:void(0);">Edit</a></li>
                            <li><a class="dropdown-item delete-btn" href="javascript:void(0);">Delete</a></li>
                            <li><a class="dropdown-item make-admin-btn" href="javascript:void(0);">Make Admin</a></li>
                        </ul>
                    </div>
                </td>
            `;

            tbody.appendChild(newRow);

            // Re-attach event listeners for the new row
            attachEventListenersToNewRow(newRow);

            // Repopulate program filter if needed
            populateProgramFilter();

            // Apply current filters
            filterTable();
        }

        // ===== ATTACH EVENT LISTENERS TO NEW ROW =====
        function attachEventListenersToNewRow(row) {
            const editBtn = row.querySelector('.edit-btn');
            const deleteBtn = row.querySelector('.delete-btn');
            const makeAdminBtn = row.querySelector('.make-admin-btn');

            if (editBtn) {
                editBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    // Trigger the same edit functionality
                    // You can call the existing edit logic here
                    // For now, we'll just log
                    console.log('Edit clicked for new row');
                });
            }

            if (deleteBtn) {
                deleteBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    // Trigger delete functionality
                    const row = this.closest('tr');
                    userToDelete = {
                        id: row.dataset.id,
                        fullName: row.dataset.fullname,
                        row: row
                    };
                    document.getElementById('deleteUserInfo').textContent = `${userToDelete.fullName}`;
                    new bootstrap.Modal(document.getElementById('deleteConfirmModal')).show();
                });
            }

            if (makeAdminBtn) {
                makeAdminBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    // Trigger make admin functionality
                    const row = this.closest('tr');
                    userToMakeAdmin = {
                        id: row.dataset.id,
                        fullName: row.dataset.fullname,
                        row: row
                    };
                    document.getElementById('makeAdminUserInfo').textContent = `${userToMakeAdmin.fullName}`;
                    new bootstrap.Modal(document.getElementById('makeAdminConfirmModal')).show();
                });
            }
        }

        // ===== INITIALIZE TOASTS WHEN DOM IS LOADED =====
        document.addEventListener('DOMContentLoaded', function() {
            // Check if Bootstrap is available
            if (typeof bootstrap !== 'undefined') {
                const successToastEl = document.getElementById('successToast');
                const errorToastEl = document.getElementById('errorToast');

                if (successToastEl) {
                    successToast = new bootstrap.Toast(successToastEl);
                }
                if (errorToastEl) {
                    errorToast = new bootstrap.Toast(errorToastEl);
                }

                toastMessage = document.getElementById('toastMessage');
                errorToastMessage = document.getElementById('errorToastMessage');

                console.log('Toasts initialized successfully');
            } else {
                console.error('Bootstrap not loaded');
            }
        });

        // ===== CREATE COMPANY FUNCTIONALITY WITH DYNAMIC ADD =====
        document.getElementById("submitCreateCompany").addEventListener("click", async () => {
            console.log("Create button clicked");

            // Get form values
            const companyData = {
                companyName: document.getElementById("companyNamePage").value,
                email: document.getElementById("companyEmailPage").value,
                password: document.getElementById("companyPasswordPage").value,
                mobileNumber: document.getElementById("companyMobilePage").value,
                address: document.getElementById("companyAddressPage").value,
                type: "Commercial",
                secId: "",
                website: "",
                tinId: "",
                description: ""
            };

            console.log("Company Data:", companyData);

            // Validate required fields
            if (!companyData.companyName || !companyData.email || !companyData.password) {
                if (errorToastMessage) errorToastMessage.textContent = "Please fill in all required fields (Company Name, Email, and Password)";
                if (errorToast) errorToast.show();
                return;
            }

            // Validate email format
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(companyData.email)) {
                if (errorToastMessage) errorToastMessage.textContent = "Please enter a valid email address";
                if (errorToast) errorToast.show();
                return;
            }

            // Validate password length
            if (companyData.password.length < 6) {
                if (errorToastMessage) errorToastMessage.textContent = "Password must be at least 6 characters long";
                if (errorToast) errorToast.show();
                return;
            }

            const token = document.getElementById('__RequestVerificationToken').value;
            console.log("Token:", token);

            const submitBtn = document.getElementById("submitCreateCompany");
            const originalText = submitBtn.textContent;

            try {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Creating...';

                console.log("Sending fetch request...");

                const response = await fetch('/Account/RegisterCompany', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(companyData)
                });

                console.log("Response status:", response.status);

                const result = await response.json();
                console.log("Result:", result);

                if (result.success) {
                    // Create a new company object for the table
                    const newCompany = {
                        id: result.userId || 'temp-id-' + Date.now(),
                        fullName: companyData.companyName,
                        email: companyData.email,
                        mobileNumber: companyData.mobileNumber,
                        address: companyData.address,
                        companyId: result.companyId || 'COMP' + Math.floor(Math.random() * 1000)
                    };

                    // Add the new company to the table
                    addNewCompanyToTable(newCompany);

                    // Clear the form
                    document.getElementById("companyNamePage").value = '';
                    document.getElementById("companyEmailPage").value = '';
                    document.getElementById("companyPasswordPage").value = '';
                    document.getElementById("companyMobilePage").value = '';
                    document.getElementById("companyAddressPage").value = '';

                    // Hide create company form and show users section
                    createCompanyWrapper.style.display = "none";
                    usersSection.style.display = "block";

                    // Clear all filters
                    clearAllFilters();

                    // Show success toast
                    if (toastMessage) toastMessage.textContent = 'Company created successfully!';
                    if (successToast) successToast.show();
                } else {
                    if (errorToastMessage) errorToastMessage.textContent = 'Error creating company: ' + (result.message || 'Unknown error');
                    if (errorToast) errorToast.show();
                }
            } catch (error) {
                console.error('Error:', error);
                if (errorToastMessage) errorToastMessage.textContent = 'An error occurred: ' + error.message;
                if (errorToast) errorToast.show();
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = originalText;
            }
        });
    </script>
</div>