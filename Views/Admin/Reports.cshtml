<script>
    document.addEventListener("DOMContentLoaded", function () {
        const cards = document.querySelectorAll(".report-card");
        const mainReports = document.getElementById("mainReports");
        const previewSection = document.getElementById("previewSection");
        const cardsContainer = document.getElementById("cardsContainer");
        const uploadModal = document.getElementById("uploadModal");
        const closeModal = document.querySelector(".close");
        const cancelUpload = document.getElementById("cancelUpload");
        const confirmUpload = document.getElementById("confirmUpload");
        const modalTitle = document.getElementById("modalTitle");
        const fileTitle = document.getElementById("fileTitle");
        const fileInput = document.getElementById("fileInput");

        let currentStudentId = null;
        let uploadType = null; // 'task' or 'document'

        // Function to update main card status based on tasks and documents
        function updateMainCardStatus(studentId) {
            const card = document.querySelector(`.report-card[data-student-key="${studentId}"]`);
            if (!card) return;

            const statusContainer = card.querySelector('.status-container .status-badge-card');

            // Check all tasks for this student
            const taskRows = document.querySelectorAll(`#tasksTable tbody tr[data-student-id="${studentId}"]`);
            const docRows = document.querySelectorAll(`#documentsTable tbody tr[data-student-id="${studentId}"]`);

            let allRead = true;

            // Check tasks
            taskRows.forEach(row => {
                const taskStatus = row.dataset.taskStatus;
                if (taskStatus === 'Unread') {
                    allRead = false;
                }
            });

            // Check documents
            docRows.forEach(row => {
                const docStatus = row.dataset.docStatus;
                if (docStatus === 'Unread') {
                    allRead = false;
                }
            });

            // Update the status badge
            if (allRead) {
                statusContainer.className = 'status-badge-card status-read';
                statusContainer.textContent = 'Read';
                card.dataset.status = 'Read';
            } else {
                statusContainer.className = 'status-badge-card status-unread';
                statusContainer.textContent = 'Unread';
                card.dataset.status = 'Unread';
            }

            // After updating status, reapply the status filter
            applyStatusFilter();
        }

        // Function to mark a student's status as Unread (when new file is uploaded)
        function markAsUnread(studentId) {
            const card = document.querySelector(`.report-card[data-student-key="${studentId}"]`);
            if (!card) return;

            const statusContainer = card.querySelector('.status-container .status-badge-card');

            // Always set to Unread when new file is uploaded
            statusContainer.className = 'status-badge-card status-unread';
            statusContainer.textContent = 'Unread';
            card.dataset.status = 'Unread';

            // After updating status, reapply the status filter
            applyStatusFilter();
        }

        // Function to apply status filter
        function applyStatusFilter() {
            const selectedStatus = document.getElementById("statusFilter").value;

            if (selectedStatus === "") {
                // Show all cards
                cards.forEach(card => {
                    card.style.display = "flex";
                });
            } else {
                // Filter by selected status
                cards.forEach(card => {
                    const cardStatus = card.dataset.status;
                    if (cardStatus === selectedStatus) {
                        card.style.display = "flex";
                    } else {
                        card.style.display = "none";
                    }
                });
            }
        }

        // Function to filter tables by student
        function filterTablesByStudent(studentId) {
            // Hide/show task rows
            document.querySelectorAll('#tasksTable tbody tr').forEach(row => {
                if (row.dataset.studentId === studentId) {
                    row.style.display = '';
                    // Uncheck any checkboxes in hidden rows
                    const checkbox = row.querySelector('.task-checkbox');
                    if (checkbox) checkbox.checked = false;
                } else {
                    row.style.display = 'none';
                }
            });

            // Hide/show document rows
            document.querySelectorAll('#documentsTable tbody tr').forEach(row => {
                if (row.dataset.studentId === studentId) {
                    row.style.display = '';
                    // Uncheck any checkboxes in hidden rows
                    const checkbox = row.querySelector('.doc-checkbox');
                    if (checkbox) checkbox.checked = false;
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Function to add a new task row
        function addNewTask(studentId, title) {
            const tbody = document.querySelector('#tasksTable tbody');
            const newTaskId = Date.now(); // Simple unique ID
            const today = new Date().toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: 'numeric' });

            const newRow = document.createElement('tr');
            newRow.dataset.taskId = newTaskId;
            newRow.dataset.taskStatus = 'Unread';
            newRow.dataset.studentId = studentId;

            newRow.innerHTML = `
                <td class="text-center"><input type="checkbox" class="task-checkbox" value="New Task"></td>
                <td class="text-center">${title}</td>
                <td class="text-center">${today}</td>
                <td class="text-center"><span class="status-badge status-unread">Unread</span></td>
                <td class="text-center">
                    <button class="download-icon download-task-btn" title="Download Task">
                        <i class="bi bi-download"></i>
                    </button>
                </td>
            `;

            tbody.appendChild(newRow);

            // Add download event listener to the new button
            const downloadBtn = newRow.querySelector('.download-task-btn');
            downloadBtn.addEventListener('click', function(e) {
                e.preventDefault();
                const row = this.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const taskId = row.dataset.taskId;
                const taskTitle = row.querySelector('td:nth-child(2)').textContent.trim();
                const studentId = row.dataset.studentId;
                const checkbox = row.querySelector('.task-checkbox');

                if (statusBadge.classList.contains('status-unread')) {
                    statusBadge.classList.remove('status-unread');
                    statusBadge.classList.add('status-read');
                    statusBadge.textContent = 'Read';
                    row.dataset.taskStatus = 'Read';

                    if (checkbox) checkbox.checked = false;
                }

                if (studentId) {
                    updateMainCardStatus(studentId);
                }

                const templateUrl = "/templates/reporttemplate.docx";
                const filename = `Task_${taskId}_${taskTitle.replace(/\s+/g, '_')}.docx`;
                const link = document.createElement('a');
                link.href = templateUrl;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }

        // Function to add a new document row
        function addNewDocument(studentId, title) {
            const tbody = document.querySelector('#documentsTable tbody');
            const newDocId = Date.now(); // Simple unique ID
            const today = new Date().toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: 'numeric' });

            const newRow = document.createElement('tr');
            newRow.dataset.docId = newDocId;
            newRow.dataset.docStatus = 'Unread';
            newRow.dataset.studentId = studentId;

            newRow.innerHTML = `
                <td class="text-center"><input type="checkbox" class="doc-checkbox" value="New Document"></td>
                <td class="text-center">${title}</td>
                <td class="text-center">${today}</td>
                <td class="text-center"><span class="status-badge status-unread">Unread</span></td>
                <td class="text-center">
                    <button class="download-icon download-doc-btn" title="Download Document">
                        <i class="bi bi-download"></i>
                    </button>
                </td>
            `;

            tbody.appendChild(newRow);

            // Add download event listener to the new button
            const downloadBtn = newRow.querySelector('.download-doc-btn');
            downloadBtn.addEventListener('click', function(e) {
                e.preventDefault();
                const row = this.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const docId = row.dataset.docId;
                const docType = row.querySelector('td:nth-child(2)').textContent.trim();
                const studentId = row.dataset.studentId;
                const checkbox = row.querySelector('.doc-checkbox');

                if (statusBadge.classList.contains('status-unread')) {
                    statusBadge.classList.remove('status-unread');
                    statusBadge.classList.add('status-read');
                    statusBadge.textContent = 'Read';
                    row.dataset.docStatus = 'Read';

                    if (checkbox) checkbox.checked = false;
                }

                if (studentId) {
                    updateMainCardStatus(studentId);
                }

                const templateUrl = "/templates/reporttemplate.docx";
                const filename = `Document_${docId}_${docType.replace(/\s+/g, '_')}.docx`;
                const link = document.createElement('a');
                link.href = templateUrl;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }

        // Initialize all cards with correct status on page load
        function initializeAllStatuses() {
            cards.forEach(card => {
                const studentId = card.dataset.studentKey;
                updateMainCardStatus(studentId);
            });
        }

        // --- Populate filter dropdowns ---
        const years = new Set();
        const programs = new Set();
        cards.forEach(card => {
            years.add(card.dataset.year);
            programs.add(card.dataset.course);
        });

        const yearFilter = document.getElementById("yearFilter");
        const programFilter = document.getElementById("programFilter");
        const statusFilter = document.getElementById("statusFilter");

        [...years].sort().forEach(year => {
            const option = document.createElement("option");
            option.value = year;
            option.textContent = year;
            yearFilter.appendChild(option);
        });

        [...programs].sort().forEach(program => {
            const option = document.createElement("option");
            option.value = program;
            option.textContent = program;
            programFilter.appendChild(option);
        });

        // --- Combined filter function ---
        function filterCards() {
            const searchTerm = document.getElementById("searchName").value.toLowerCase();
            const selectedYear = yearFilter.value;
            const selectedProgram = programFilter.value;
            const selectedStatus = statusFilter.value;

            cards.forEach(card => {
                const name = card.dataset.name.toLowerCase();
                const year = card.dataset.year;
                const program = card.dataset.course;
                const status = card.dataset.status;

                let show = true;
                if (searchTerm && !name.includes(searchTerm)) show = false;
                if (selectedYear && year !== selectedYear) show = false;
                if (selectedProgram && program !== selectedProgram) show = false;
                if (selectedStatus && status !== selectedStatus) show = false;

                card.style.display = show ? "flex" : "none";
            });
        }

        document.getElementById("searchName").addEventListener("input", filterCards);
        yearFilter.addEventListener("change", filterCards);
        programFilter.addEventListener("change", filterCards);
        statusFilter.addEventListener("change", filterCards);

        // --- Preview button (eye icon) ---
        document.querySelectorAll('.preview-btn').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const card = this.closest('.report-card');
                currentStudentId = card.dataset.studentKey;

                // Filter tables to show only this student's data
                filterTablesByStudent(currentStudentId);

                document.getElementById("previewProfilePic").src = card.dataset.profile && card.dataset.profile.trim() !== ""
                    ? card.dataset.profile
                    : "/images/defaultpicture.jpg";

                document.getElementById("pName").textContent = card.dataset.name || "—";
                document.getElementById("pStudentID").textContent = card.dataset.studentid || "—";
                document.getElementById("pCourse").textContent = card.dataset.course || "—";
                document.getElementById("pYear").textContent = card.dataset.year || "—";

                const fbSpan = document.getElementById("pFacebook");
                const fbUsername = card.dataset.facebook;
                if (fbUsername && fbUsername.trim() !== "") {
                    fbSpan.innerHTML = `<a href="https://facebook.com/${fbUsername}" target="_blank" class="info-link">${fbUsername}</a>`;
                } else {
                    fbSpan.textContent = "—";
                }

                document.getElementById("pMobileNumber").textContent = card.dataset.mobilenumber || "—";
                document.getElementById("pAddress").textContent = card.dataset.address || "—";
                document.getElementById("pContactNumber").textContent = card.dataset.contactnumber || "—";
                document.getElementById("pBirthdate").textContent = card.dataset.birthdate || "—";
                document.getElementById("pEmail").textContent = card.dataset.email || "—";

                const companySpan = document.getElementById("pCompany");
                const company = card.dataset.company;
                if (company && company.trim() !== "") {
                    companySpan.innerHTML = `<a href="https://www.google.com/search?q=${encodeURIComponent(company)}" target="_blank" class="info-link">${company}</a>`;
                } else {
                    companySpan.textContent = "—";
                }

                mainReports.style.display = "none";
                previewSection.style.display = "block";
            });
        });

        // --- Upload button handlers ---
        document.getElementById("uploadTaskBtn").addEventListener("click", function() {
            uploadType = 'task';
            modalTitle.textContent = 'Upload New Task';
            fileTitle.value = '';
            fileInput.value = '';
            uploadModal.style.display = 'block';
        });

        document.getElementById("uploadDocumentBtn").addEventListener("click", function() {
            uploadType = 'document';
            modalTitle.textContent = 'Upload New Document';
            fileTitle.value = '';
            fileInput.value = '';
            uploadModal.style.display = 'block';
        });

        // --- Modal close handlers ---
        function closeUploadModal() {
            uploadModal.style.display = 'none';
            uploadType = null;
        }

        closeModal.addEventListener('click', closeUploadModal);
        cancelUpload.addEventListener('click', closeUploadModal);

        window.addEventListener('click', function(event) {
            if (event.target === uploadModal) {
                closeUploadModal();
            }
        });

        // --- Confirm upload handler ---
        confirmUpload.addEventListener('click', function() {
            if (!fileTitle.value.trim()) {
                alert('Please enter a file title');
                return;
            }

            if (!fileInput.files || fileInput.files.length === 0) {
                alert('Please select a file to upload');
                return;
            }

            // Simulate upload (in real app, you'd send to server)
            alert(`File "${fileInput.files[0].name}" uploaded successfully!`);

            // Add new row based on upload type
            if (uploadType === 'task') {
                addNewTask(currentStudentId, fileTitle.value);
            } else if (uploadType === 'document') {
                addNewDocument(currentStudentId, fileTitle.value);
            }

            // Mark the student's main status as Unread
            markAsUnread(currentStudentId);

            closeUploadModal();
        });

        // --- Back button ---
        document.getElementById("backBtn").addEventListener("click", function () {
            previewSection.style.display = "none";
            mainReports.style.display = "block";

            // Show all rows again and uncheck all checkboxes
            document.querySelectorAll('#tasksTable tbody tr, #documentsTable tbody tr').forEach(row => {
                row.style.display = '';
                // Uncheck all checkboxes
                const taskCheckbox = row.querySelector('.task-checkbox');
                const docCheckbox = row.querySelector('.doc-checkbox');
                if (taskCheckbox) taskCheckbox.checked = false;
                if (docCheckbox) docCheckbox.checked = false;
            });

            currentStudentId = null;
        });

        // --- TASKS download (bulk) - Only visible checkboxes ---
        document.getElementById("downloadTemplateBtn").addEventListener("click", function (e) {
            e.preventDefault();

            // Only get checkboxes from visible rows (current student)
            const visibleCheckboxes = [...document.querySelectorAll("#tasksTable tbody tr:not([style*='none']) .task-checkbox:checked")];

            if (visibleCheckboxes.length === 0) {
                alert("Please select at least one task.");
                return;
            }

            visibleCheckboxes.forEach(cb => {
                const row = cb.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const taskId = row.dataset.taskId;
                const taskTitle = row.querySelector('td:nth-child(2)').textContent.trim();
                const studentId = row.dataset.studentId;

                if (statusBadge && statusBadge.classList.contains('status-unread')) {
                    statusBadge.classList.remove('status-unread');
                    statusBadge.classList.add('status-read');
                    statusBadge.textContent = 'Read';
                    row.dataset.taskStatus = 'Read';

                    // Uncheck the checkbox after download
                    cb.checked = false;
                }

                // Update main card status for this student
                if (studentId) {
                    updateMainCardStatus(studentId);
                }

                const templateUrl = "/templates/reporttemplate.docx";
                const filename = `Task_${taskId}_${taskTitle.replace(/\s+/g, '_')}.docx`;
                const link = document.createElement('a');
                link.href = templateUrl;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        });

        // --- TASKS per-row download ---
        function addTaskDownloadListener(btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
