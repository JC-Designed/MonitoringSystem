                    statusBadge.classList.remove('status-unread');
                    statusBadge.classList.add('status-read');
                    statusBadge.textContent = 'Read';
                    row.dataset.taskStatus = 'Read';

                    // Uncheck the checkbox after download
                    if (checkbox) checkbox.checked = false;
                }

                // Update main card status for this student
                if (studentId) {
                    updateMainCardStatus(studentId);
                }

                const templateUrl = "/templates/reporttemplate.docx";
                const filename = `Task_${taskId}_${taskTitle.replace(/\s+/g, '_')}.docx`;
                const link = document.createElement('a');
                link.href = templateUrl;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }

        document.querySelectorAll('.download-task-btn').forEach(btn => {
            addTaskDownloadListener(btn);
        });

        // --- DOCUMENTS download (bulk) - Only visible checkboxes ---
        document.getElementById("downloadDocumentsBtn").addEventListener("click", function (e) {
            e.preventDefault();

            // Only get checkboxes from visible rows (current student)
            const visibleCheckboxes = [...document.querySelectorAll("#documentsTable tbody tr:not([style*='none']) .doc-checkbox:checked")];

            if (visibleCheckboxes.length === 0) {
                alert("Please select at least one document.");
                return;
            }

            visibleCheckboxes.forEach(cb => {
                const row = cb.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const docId = row.dataset.docId;
                const docType = row.querySelector('td:nth-child(2)').textContent.trim();
                const studentId = row.dataset.studentId;

                if (statusBadge && statusBadge.classList.contains('status-unread')) {
                    statusBadge.classList.remove('status-unread');
                    statusBadge.classList.add('status-read');
                    statusBadge.textContent = 'Read';
                    row.dataset.docStatus = 'Read';

                    // Uncheck the checkbox after download
                    cb.checked = false;
                }

                // Update main card status for this student
                if (studentId) {
                    updateMainCardStatus(studentId);
                }

                const templateUrl = "/templates/reporttemplate.docx";
                const filename = `Document_${docId}_${docType.replace(/\s+/g, '_')}.docx`;
                const link = document.createElement('a');
                link.href = templateUrl;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        });

        // --- DOCUMENTS per-row download ---
        function addDocumentDownloadListener(btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const row = this.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const docId = row.dataset.docId;
                const docType = row.querySelector('td:nth-child(2)').textContent.trim();
                const studentId = row.dataset.studentId;
                const checkbox = row.querySelector('.doc-checkbox');

                if (statusBadge.classList.contains('status-unread')) {
                    statusBadge.classList.remove('status-unread');
                    statusBadge.classList.add('status-read');
                    statusBadge.textContent = 'Read';
                    row.dataset.docStatus = 'Read';

                    // Uncheck the checkbox after download
                    if (checkbox) checkbox.checked = false;
                }

                // Update main card status for this student
                if (studentId) {
                    updateMainCardStatus(studentId);
                }

                const templateUrl = "/templates/reporttemplate.docx";
                const filename = `Document_${docId}_${docType.replace(/\s+/g, '_')}.docx`;
                const link = document.createElement('a');
                link.href = templateUrl;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }

        document.querySelectorAll('.download-doc-btn').forEach(btn => {
            addDocumentDownloadListener(btn);
        });

        // Initialize all statuses on page load
        initializeAllStatuses();
    });
</script>