    <button class="btn btn-primary mb-3" id="backBtn">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </button>

    <div class="mb-4 text-center text-md-start">
        <img id="previewProfilePic" src="/images/defaultpicture.jpg"
             class="rounded-circle shadow"
             alt="Profile Picture"
             loading="lazy"
             onerror="this.src='/images/defaultpicture.jpg';">
    </div>

    <div class="card shadow-sm rounded-4 p-4 student-info-card">
        <h5 class="fw-bold border-bottom pb-2 mb-4">Student Information</h5>
        <div class="row g-4">
            <div class="col-md-6"><strong>Name:</strong> <span id="pName"></span></div>
            <div class="col-md-6"><strong>Student ID:</strong> <span id="pStudentID"></span></div>
            <div class="col-md-6"><strong>Program:</strong> <span id="pCourse"></span></div>
            <div class="col-md-6"><strong>Year:</strong> <span id="pYear"></span></div>
            <div class="col-md-6"><strong>Facebook:</strong> <span id="pFacebook"></span></div>
            <div class="col-md-6"><strong>Mobile Number:</strong> <span id="pMobileNumber"></span></div>
            <div class="col-md-6"><strong>Address:</strong> <span id="pAddress"></span></div>
            <div class="col-md-6"><strong>Contact Person:</strong> <span id="pContactPerson"></span></div>
            <div class="col-md-6"><strong>Birthdate:</strong> <span id="pBirthdate"></span></div>
            <div class="col-md-6"><strong>Email:</strong> <span id="pEmail"></span></div>
            <div class="col-md-6"><strong>Company:</strong> <span id="pCompany"></span></div>
            <div class="col-md-6"><strong>Total Allotted Hours:</strong> <span id="pTotalHours"></span></div>
        </div>
    </div>

    <!-- TASKS SECTION -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <h5 class="fw-bold mb-0">Tasks</h5>
        <div>
            <button id="downloadTemplateBtn" class="btn btn-danger">
                <i class="bi bi-download"></i> Download Template
            </button>
        </div>
    </div>

    <div id="tasksTable" class="mt-4 p-4 rounded-4 shadow-sm data-table">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="text-center">
                    <tr>
                        <th>Select</th>
                        <th>Task Title</th>
                        <th>Date Uploaded</th>
                        <th>Read Status</th>
                        <th>Download</th>
                </thead>
                <tbody id="tasksTableBody">
                    <tr><td colspan="5" class="text-center text-muted py-4">Select a student to view tasks</td>
                </tbody>
            </table>
        </div>
    </div>

    <!-- DOCUMENTS & REPORTS SECTION -->
    <div class="d-flex justify-content-between align-items-center mt-5">
        <h5 class="fw-bold mb-0">Documents & Reports</h5>
        <div>
            <button id="downloadDocumentsBtn" class="btn btn-danger">
                <i class="bi bi-download"></i> Download Selected
            </button>
        </div>
    </div>

    <div id="documentsTable" class="mt-4 p-4 rounded-4 shadow-sm data-table">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="text-center">
                    <tr>
                        <th>Select</th>
                        <th>Name</th>
                        <th>Date</th>
                        <th>Read Status</th>
                        <th>Download</th>
                </thead>
                <tbody id="documentsTableBody">
                    <tr><td colspan="5" class="text-center text-muted py-4">Select a student to view documents and reports</td>
                </tbody>
            </table>
        </div>
    </div>

    <!-- TIME LOGS SECTION -->
    <div class="d-flex justify-content-between align-items-center mt-5">
        <h5 class="fw-bold mb-0">Time Logs</h5>
        <div>
            <button id="downloadTimeLogsBtn" class="btn btn-danger">
                <i class="bi bi-download"></i> Download Selected
            </button>
        </div>
    </div>

    <div id="timeLogsTable" class="mt-4 p-4 rounded-4 shadow-sm data-table">
        <div class="table-responsive">
            <table class="table mb-0 align-middle">
                <thead class="text-center">
                    <tr>
                        <th>Select</th>
                        <th>Month</th>
                        <th>Total Hours</th>
                        <th>Submission Date</th>
                        <th>Read Status</th>
                        <th>Download</th>
                </thead>
                <tbody id="timeLogsTableBody">
                    <tr><td colspan="6" class="text-center text-muted py-4">Select a student to view time logs</td>
                </tbody>
            </table>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<script>
    (function() {
        'use strict';

        const AppState = {
            currentStudentId: null,
            students: @Html.Raw(Json.Serialize(students)),
            tasks: @Html.Raw(Json.Serialize(tasks)),
            documents: @Html.Raw(Json.Serialize(documents)),
            timeLogs: @Html.Raw(Json.Serialize(timeLogSubmissions)),
            reports: @Html.Raw(Json.Serialize(reports)),

            elements: {
                cardsContainer: document.getElementById('cardsContainer'),
                mainReports: document.getElementById('studentsTab'),
                previewSection: document.getElementById('previewSection'),
                tasksTableBody: document.getElementById('tasksTableBody'),
                documentsTableBody: document.getElementById('documentsTableBody'),
                timeLogsTableBody: document.getElementById('timeLogsTableBody'),
                backBtn: document.getElementById('backBtn'),
                downloadTemplateBtn: document.getElementById('downloadTemplateBtn'),
                downloadDocumentsBtn: document.getElementById('downloadDocumentsBtn'),
                downloadTimeLogsBtn: document.getElementById('downloadTimeLogsBtn'),
                searchName: document.getElementById('searchName'),
                yearFilter: document.getElementById('yearFilter'),
                programFilter: document.getElementById('programFilter'),
                statusFilter: document.getElementById('statusFilter')
            }
        };

        const Utils = {
            formatDate(dateString) {
                if (!dateString) return '—';
                try {
                    return new Date(dateString).toLocaleDateString('en-US', {
                        month: '2-digit',
                        day: '2-digit',
                        year: 'numeric'
                    });
                } catch {
                    return '—';
                }
            },

            getMonthName(month) {
                const months = ['January', 'February', 'March', 'April', 'May', 'June',
                    'July', 'August', 'September', 'October', 'November', 'December'];
                return months[month - 1] || 'Unknown';
            },

            showToast(message, type = 'success') {
                let toastContainer = document.getElementById('toast-container');
                if (!toastContainer) {
                    toastContainer = document.createElement('div');
                    toastContainer.id = 'toast-container';
                    document.body.appendChild(toastContainer);
                }

                const toast = document.createElement('div');
                toast.className = `toast toast-${type}`;
                toast.innerHTML = `
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <span style="font-size: 18px; font-weight: bold;">${type === 'success' ? '✓' : type === 'error' ? '✗' : 'ℹ'}</span>
                        <span>${message}</span>
                    </div>
                    <button class="toast-close" onclick="this.parentElement.remove()">×</button>
                `;

                toastContainer.appendChild(toast);
                setTimeout(() => {
                    if (toast.parentElement) {
                        toast.style.animation = 'slideOut 0.3s ease';
                        setTimeout(() => toast.remove(), 300);
                    }
                }, 3000);
            },

            getAntiForgeryToken() {
                return document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            },

            getStudentInfo(studentId) {
                const student = AppState.students.find(s => s.id === studentId);
                const studentCard = document.querySelector(`.report-card[data-student-key="${studentId}"]`);
                return { student: student, card: studentCard };
            },

            async markDocumentAsRead(docId) {
                try {
                    const token = this.getAntiForgeryToken();
                    const response = await fetch(`/Admin/MarkDocumentAsRead/${docId}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/json' }
                    });
                    return await response.json();
                } catch (error) {
                    console.error('Error marking document as read:', error);
                    return { success: false };
                }
            },

            async markTimeLogAsRead(submissionId) {
                try {
                    const token = this.getAntiForgeryToken();
                    const response = await fetch(`/Admin/MarkTimeLogAsRead/${submissionId}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/json' }
                    });
                    return await response.json();
                } catch (error) {
                    console.error('Error marking time log as read:', error);
                    return { success: false };
                }
            },

            async markReportAsRead(reportId) {
                try {
                    const token = this.getAntiForgeryToken();
                    const response = await fetch(`/Admin/MarkReportAsRead/${reportId}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/json' }
                    });
                    return await response.json();
                } catch (error) {
                    console.error('Error marking report as read:', error);
                    return { success: false };
                }
            }
        };

        const FilterManager = {
            filterCards() {
                const searchTerm = AppState.elements.searchName.value.toLowerCase();
                const selectedYear = AppState.elements.yearFilter.value;
                const selectedProgram = AppState.elements.programFilter.value;
                const selectedStatus = AppState.elements.statusFilter.value;

                document.querySelectorAll('.report-card').forEach(card => {
                    const name = card.dataset.name?.toLowerCase() || '';
                    const year = card.dataset.year;
                    const program = card.dataset.course;
                    const status = card.dataset.status;

                    let show = true;
                    if (searchTerm && !name.includes(searchTerm)) show = false;
                    if (selectedYear && year !== selectedYear) show = false;
                    if (selectedProgram && program !== selectedProgram) show = false;
                    if (selectedStatus && status !== selectedStatus) show = false;

                    card.style.display = show ? 'flex' : 'none';
                });
            },

            init() {
                AppState.elements.searchName.addEventListener('input', () => this.filterCards());
                AppState.elements.yearFilter.addEventListener('change', () => this.filterCards());
                AppState.elements.programFilter.addEventListener('change', () => this.filterCards());
                AppState.elements.statusFilter.addEventListener('change', () => this.filterCards());
            }
        };

        const TaskManager = {
            renderTasksForStudent(studentId) {
                const studentTasks = AppState.tasks.filter(t => t.studentId === studentId);
                const tbody = AppState.elements.tasksTableBody;

                if (studentTasks.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">No tasks found for this student</td></tr>';
                    return;
                }

                const sortedTasks = [...studentTasks].sort((a, b) => {
                    if (a.status === 'Unread' && b.status !== 'Unread') return -1;
                    if (a.status !== 'Unread' && b.status === 'Unread') return 1;
                    return new Date(b.createdAt) - new Date(a.createdAt);
                });

                tbody.innerHTML = sortedTasks.map(task => {
                    const date = Utils.formatDate(task.createdAt);
                    const status = task.status || 'Unread';
                    const statusClass = status === 'Unread' ? 'status-unread' : 'status-read';

                    return `
                        <tr data-task-id="${task.id}" data-task-status="${status}" data-student-id="${task.studentId}">
                            <td class="text-center"><input type="checkbox" class="task-checkbox" value="${task.id}"></td>
                            <td class="text-center">${task.title || 'Untitled'}</td>
                            <td class="text-center">${date}</td>
                            <td class="text-center"><span class="status-badge ${statusClass}">${status}</span></td>
                            <td class="text-center"><button class="download-link download-task-btn">DOWNLOAD</button></td>
                        </tr>
                    `;
                }).join('');
                this.attachDownloadListeners();
            },

            attachDownloadListeners() {
                document.querySelectorAll('.download-task-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => this.handleTaskDownload(e));
                });
            },

            generateTaskExcel(taskTitle, studentId) {
                const { student, card } = Utils.getStudentInfo(studentId);
                let csv = "STUDENT TASK REPORT\n" + "=".repeat(50) + "\n\n";
                csv += "STUDENT INFORMATION\n" + "-".repeat(30) + "\n";
                csv += "Full Name," + (student?.fullName || card?.dataset.name || 'N/A') + "\n";
                csv += "Student ID," + (student?.studentId || card?.dataset.studentid || 'N/A') + "\n";
                csv += "Program," + (student?.program || card?.dataset.course || 'N/A') + "\n";
                csv += "Year," + (student?.year || card?.dataset.year || 'N/A') + "\n";
                csv += "Email," + (student?.email || card?.dataset.email || 'N/A') + "\n";
                csv += "Mobile Number," + (student?.mobileNumber || card?.dataset.mobilenumber || 'N/A') + "\n";
                csv += "Company," + (card?.dataset.company || 'N/A') + "\n\n";
                csv += "TASK INFORMATION\n" + "-".repeat(30) + "\n";
                csv += "Task Title," + taskTitle + "\n";
                csv += "Status,Completed\n";
                csv += "Download Date," + new Date().toLocaleDateString() + "\n";
                csv += "Download Time," + new Date().toLocaleTimeString() + "\n";

                const studentName = (student?.fullName || card?.dataset.name || 'Student').replace(/\s+/g, '_');
                const fileName = `Task_${studentName}_${taskTitle.replace(/\s+/g, '_')}_${new Date().toISOString().split('T')[0]}.csv`;

                const blob = new Blob(["\uFEFF" + csv], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(url);
                Utils.showToast(`Task downloaded as Excel`, 'success');
            },

            handleTaskDownload(e) {
                e.preventDefault();
                const row = e.currentTarget.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const taskId = row.dataset.taskId;
                const taskTitle = row.querySelector('td:nth-child(2)').textContent.trim();
                const studentId = row.dataset.studentId;

                if (statusBadge.classList.contains('status-unread')) {
                    statusBadge.classList.remove('status-unread');
                    statusBadge.classList.add('status-read');
                    statusBadge.textContent = 'Read';
                    row.dataset.taskStatus = 'Read';
                    const task = AppState.tasks.find(t => t.id == taskId);
                    if (task) task.status = 'Read';
                    StudentManager.updateMainCardStatusFromAllSources(studentId);
                    this.renderTasksForStudent(studentId);
                }
                this.generateTaskExcel(taskTitle, studentId);
            }
        };

        const DocumentManager = {
            renderDocumentsForStudent(studentId) {
                const studentDocs = AppState.documents.filter(d => d.studentId === studentId);
                const studentReports = AppState.reports.filter(r => r.studentId === studentId);

                const allItems = [
                    ...studentDocs.map(d => ({ ...d, itemType: 'document' })),
                    ...studentReports.map(r => ({ ...r, itemType: 'report' }))
                ].sort((a, b) => {
                    if (a.status === 'Unread' && b.status !== 'Unread') return -1;
                    if (a.status !== 'Unread' && b.status === 'Unread') return 1;
                    const dateA = a.uploadedAt || a.dateFrom;
                    const dateB = b.uploadedAt || b.dateFrom;
                    return new Date(dateB) - new Date(dateA);
                });

                const tbody = AppState.elements.documentsTableBody;

                if (allItems.length === 0) {
                    tbody.innerHTML = '=<td colspan="5" class="text-center text-muted py-4">No documents or reports found for this student<!td>';
                    return;
                }

                tbody.innerHTML = allItems.map(item => {
                    const date = Utils.formatDate(item.uploadedAt || item.dateFrom);
                    const status = item.status || 'Unread';
                    const statusClass = status === 'Unread' ? 'status-unread' : 'status-read';
                    const name = item.name || item.title;
                    const itemType = item.itemType;
                    const typeIcon = itemType === 'document' ? 'bi-file-earmark-text' : 'bi-file-earmark-post';
                    const typeColor = itemType === 'document' ? '#0d6efd' : '#198754';
                    const hasFile = itemType === 'document' ? true : (item.filePath && item.filePath !== '');

                    return `
                        <tr data-${itemType}-id="${item.id}" data-student-id="${studentId}" data-item-type="${itemType}" data-status="${status}">
                            <td class="text-center"><input type="checkbox" class="${itemType}-checkbox" value="${item.id}" data-type="${itemType}">\(
                            <td class="text-center">
                                <i class="bi ${typeIcon} me-2" style="color: ${typeColor};"></i>
                                <span class="badge bg-secondary">${itemType === 'document' ? 'Document' : 'Report'}</span>
                                ${name}
                                </td>
                            <td class="text-center">${date}</td>
                            <td class="text-center"><span class="status-badge ${statusClass}">${status}</span></td>
                            <td class="text-center">
                                ${hasFile ? `<button class="download-link download-${itemType}-btn" data-id="${item.id}" data-type="${itemType}">DOWNLOAD</button>` : '<span class="text-muted">No file</span>'}
                            </td>
                         </tr>
                    `;
                }).join('');
                this.attachDownloadListeners();
            },

            attachDownloadListeners() {
                document.querySelectorAll('.download-document-btn, .download-report-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => this.handleItemDownload(e));
                });
            },

            async handleItemDownload(e) {
                e.preventDefault();
                const row = e.currentTarget.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const itemId = e.currentTarget.dataset.id;
                const itemType = e.currentTarget.dataset.type;
                const studentId = row.dataset.studentId;

                if (statusBadge.classList.contains('status-unread')) {
                    let result;
                    if (itemType === 'document') {
                        result = await Utils.markDocumentAsRead(itemId);
                        if (result.success) {
                            const doc = AppState.documents.find(d => d.id == itemId);
                            if (doc) { doc.status = 'Read'; doc.isRead = true; }
                        }
                    } else {
                        result = await Utils.markReportAsRead(itemId);
                        if (result.success) {
                            const report = AppState.reports.find(r => r.id == parseInt(itemId));
                            if (report) { report.status = 'Read'; report.isRead = true; }
                        }
                    }

                    if (result.success) {
                        statusBadge.classList.remove('status-unread');
                        statusBadge.classList.add('status-read');
                        statusBadge.textContent = 'Read';
                        row.dataset.status = 'Read';
                        StudentManager.updateMainCardStatusFromAllSources(studentId);
                        this.renderDocumentsForStudent(studentId);
                    }
                }

                if (itemType === 'document') {
                    window.location.href = `/Admin/DownloadDocument/${itemId}`;
                    Utils.showToast('Downloading document...', 'info');
                } else {
                    const report = AppState.reports.find(r => r.id == parseInt(itemId));
                    if (report && report.filePath) {
                        const link = document.createElement('a');
                        link.href = report.filePath;
                        link.download = report.filePath.split('/').pop();
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        Utils.showToast('Report downloaded successfully!', 'success');
                    } else {
                        Utils.showToast('No file attached to this report', 'error');
                    }
                }
            },

            downloadSelected() {
                const selectedItems = document.querySelectorAll('#documentsTable tbody tr input:checked');
                if (selectedItems.length === 0) {
                    Utils.showToast('Please select at least one item to download.', 'error');
                    return;
                }

                let csv = "SELECTED ITEMS MANIFEST\n" + "=".repeat(50) + "\n";
                csv += "Generated on:," + new Date().toLocaleString() + "\n\n";
                csv += "Type,Name,Date,Status\n";

                selectedItems.forEach(cb => {
                    const row = cb.closest('tr');
                    const typeCell = row.querySelector('td:nth-child(2)');
                    const type = typeCell.querySelector('.badge')?.textContent || 'Item';
                    const name = typeCell.textContent.replace(type, '').trim();
                    const date = row.querySelector('td:nth-child(3)').textContent.trim();
                    const status = row.querySelector('.status-badge').textContent.trim();
                    csv += `${type},${name},${date},${status}\n`;
                });

                const blob = new Blob(["\uFEFF" + csv], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = `Selected_Items_${new Date().toISOString().split('T')[0]}.csv`;
                link.click();
                URL.revokeObjectURL(url);
                Utils.showToast(`Generated manifest for ${selectedItems.length} item(s)`, 'success');
                selectedItems.forEach(cb => cb.checked = false);
                if (AppState.currentStudentId) this.renderDocumentsForStudent(AppState.currentStudentId);
            }
        };

        const TimeLogManager = {
            renderTimeLogsForStudent(studentId) {
                const studentTimeLogs = AppState.timeLogs.filter(t => t.studentId === studentId);
                const tbody = AppState.elements.timeLogsTableBody;

                if (studentTimeLogs.length === 0) {
                    tbody.innerHTML = '=<td colspan="6" class="text-center text-muted py-4">No time logs found for this student<!td>';
                    return;
                }

                const sortedLogs = [...studentTimeLogs].sort((a, b) => {
                    if (!a.isRead && b.isRead) return -1;
                    if (a.isRead && !b.isRead) return 1;
                    return new Date(b.submissionDate) - new Date(a.submissionDate);
                });

                tbody.innerHTML = sortedLogs.map(log => {
                    const date = Utils.formatDate(log.submissionDate);
                    const status = log.status || 'Unread';
                    const statusClass = status === 'Unread' ? 'status-unread' : 'status-read';

                    return `
                        <tr data-submission-id="${log.id}" data-student-id="${studentId}" data-submission-status="${status}">
                            <td class="text-center"><input type="checkbox" class="timelog-checkbox" value="${log.id}">\(
                            <td class="text-center">${log.monthName}</td>
                            <td class="text-center">${log.totalHours} hrs</td>
                            <td class="text-center">${date}</td>
                            <td class="text-center"><span class="status-badge ${statusClass}">${status}</span></td>
                            <td class="text-center"><button class="download-link download-timelog-btn">DOWNLOAD</button></td>
                         </tr>
                    `;
                }).join('');
                this.attachDownloadListeners();
            },

            attachDownloadListeners() {
                document.querySelectorAll('.download-timelog-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => this.handleTimeLogDownload(e));
                });
            },

            async handleTimeLogDownload(e) {
                e.preventDefault();
                const row = e.currentTarget.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const submissionId = row.dataset.submissionId;
                const studentId = row.dataset.studentId;

                if (statusBadge.classList.contains('status-unread')) {
                    const result = await Utils.markTimeLogAsRead(submissionId);
                    if (result.success) {
                        statusBadge.classList.remove('status-unread');
                        statusBadge.classList.add('status-read');
                        statusBadge.textContent = 'Read';
                        row.dataset.submissionStatus = 'Read';
                        const timeLog = AppState.timeLogs.find(t => t.id == submissionId);
                        if (timeLog) { timeLog.status = 'Read'; timeLog.isRead = true; }
                        StudentManager.updateMainCardStatusFromAllSources(studentId);
                        this.renderTimeLogsForStudent(studentId);
                    }
                }
                window.downloadTimeLogSubmission(submissionId);
            }
        };

        window.downloadTimeLogSubmission = function(submissionId) {
            const submission = AppState.timeLogs.find(s => s.id === submissionId);
            if (!submission) return;

            try {
                let logsData = submission.logs;
                if (typeof logsData === 'string') {
                    try { logsData = JSON.parse(logsData); } catch (e) { logsData = []; }
                }

                const { student, card } = Utils.getStudentInfo(submission.studentId);
                const row = document.querySelector(`tr[data-submission-id="${submissionId}"]`);
                const currentStatus = row ? row.querySelector('.status-badge').textContent.trim() : (submission.status || 'Unread');

                let csv = "STUDENT TIME LOG REPORT\n" + "=".repeat(60) + "\n\n";
                csv += "STUDENT INFORMATION\n" + "-".repeat(40) + "\n";
                csv += "Full Name," + (submission.studentName || student?.fullName || card?.dataset.name || 'N/A') + "\n";
                csv += "Student ID," + (student?.studentId || card?.dataset.studentid || 'N/A') + "\n";
                csv += "Program," + (student?.program || submission.course || card?.dataset.course || 'N/A') + "\n";
                csv += "Year," + (student?.year || submission.year || card?.dataset.year || 'N/A') + "\n";
                csv += "Section," + (submission.section || 'N/A') + "\n";
                csv += "Email," + (student?.email || card?.dataset.email || 'N/A') + "\n";
                csv += "Mobile Number," + (student?.mobileNumber || card?.dataset.mobilenumber || 'N/A') + "\n\n";
                csv += "TIME LOG DETAILS\n" + "-".repeat(40) + "\n";
                csv += "Month," + submission.monthName + "\n";
                csv += "Total Hours Rendered," + submission.totalHours + "\n";
                csv += "Status," + currentStatus + "\n";
                csv += "Submission Date," + new Date(submission.submissionDate).toLocaleDateString() + "\n\n";
                if (submission.adminRemarks) csv += "Admin Remarks," + submission.adminRemarks + "\n\n";
                csv += "DAILY TIME RECORD\n" + "=".repeat(100) + "\n";
                csv += "Day,AM In,AM Out,PM In,PM Out,OT In,OT Out,Total Hours,Type\n" + "-".repeat(100) + "\n";

                if (Array.isArray(logsData) && logsData.length > 0) {
                    logsData.sort((a, b) => new Date(a.date) - new Date(b.date)).forEach(log => {
                        const day = new Date(log.date).getDate();
                        if (log.type === 'regular') {
                            csv += `${day},${log.amIn || '-'},${log.amOut || '-'},${log.pmIn || '-'},${log.pmOut || '-'},${log.otIn || '-'},${log.otOut || '-'},${log.totalHours || 0},Regular\n`;
                        } else {
                            csv += `${day},-,-,-,-,-,-,-,${log.type}\n`;
                        }
                    });
                }

                csv += "\n" + "=".repeat(60) + "\nSUMMARY\n" + "=".repeat(60) + "\n";
                csv += "Total Days Worked," + logsData.length + "\n";
                csv += "Total Hours Rendered," + submission.totalHours + "\n";
                csv += "Average Hours Per Day," + (logsData.length > 0 ? (submission.totalHours / logsData.length).toFixed(2) : '0') + "\n";

                const studentName = (submission.studentName || student?.fullName || 'Student').replace(/\s+/g, '_');
                const fileName = `TimeLog_${studentName}_${submission.monthName}_${new Date().toISOString().split('T')[0]}.csv`;

                const blob = new Blob(["\uFEFF" + csv], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(url);
                Utils.showToast('Time log downloaded!', 'success');
            } catch (error) {
                console.error('Error downloading time log:', error);
                Utils.showToast('Error downloading time log', 'error');
            }
        };

        const StudentManager = {
            updateMainCardStatusFromAllSources(studentId) {
                const card = document.querySelector(`.report-card[data-student-key="${studentId}"]`);
                if (!card) return;

                const hasUnreadTasks = AppState.tasks.some(t => t.studentId === studentId && t.status === 'Unread');
                const hasUnreadDocuments = AppState.documents.some(d => d.studentId === studentId && !d.isRead);
                const hasUnreadTimeLogs = AppState.timeLogs.some(t => t.studentId === studentId && !t.isRead);
                const hasUnreadReports = AppState.reports.some(r => r.studentId === studentId && r.status === 'Unread');

                const hasUnread = hasUnreadTasks || hasUnreadDocuments || hasUnreadTimeLogs || hasUnreadReports;
                const newStatus = hasUnread ? 'Unread' : 'Read';

                const statusContainer = card.querySelector('.status-container .status-badge');
                statusContainer.className = `status-badge ${hasUnread ? 'status-unread' : 'status-read'}`;
                statusContainer.textContent = newStatus;
                card.dataset.status = newStatus;
                card.dataset.hasunread = hasUnread ? 'true' : 'false';
                FilterManager.filterCards();
            },

            showPreview(card) {
                AppState.currentStudentId = card.dataset.studentKey;
                TaskManager.renderTasksForStudent(AppState.currentStudentId);
                DocumentManager.renderDocumentsForStudent(AppState.currentStudentId);
                TimeLogManager.renderTimeLogsForStudent(AppState.currentStudentId);

                document.getElementById('previewProfilePic').src = card.dataset.profile && card.dataset.profile.trim() !== '' ? card.dataset.profile : '/images/defaultpicture.jpg';
                document.getElementById('pName').textContent = card.dataset.name || '—';
                document.getElementById('pStudentID').textContent = card.dataset.studentid || '—';
                document.getElementById('pCourse').textContent = card.dataset.course || '—';
                document.getElementById('pYear').textContent = card.dataset.year || '—';

                const fbSpan = document.getElementById('pFacebook');
                const fbUsername = card.dataset.facebook;
                if (fbUsername && fbUsername.trim() !== '') {
                    fbSpan.innerHTML = `<a href="https://facebook.com/${fbUsername}" target="_blank" class="info-link">${fbUsername}</a>`;
                } else { fbSpan.textContent = '—'; }

                document.getElementById('pMobileNumber').textContent = card.dataset.mobilenumber || '—';
                document.getElementById('pAddress').textContent = card.dataset.address || '—';
                document.getElementById('pContactPerson').textContent = card.dataset.contactperson || '—';
                document.getElementById('pBirthdate').textContent = card.dataset.birthdate || '—';
                document.getElementById('pEmail').textContent = card.dataset.email || '—';

                const companySpan = document.getElementById('pCompany');
                const company = card.dataset.company;
                if (company && company.trim() !== '') {
                    companySpan.innerHTML = `<a href="https://www.google.com/search?q=${encodeURIComponent(company)}" target="_blank" class="info-link">${company}</a>`;
                } else { companySpan.textContent = '—'; }

                document.getElementById('pTotalHours').textContent = card.dataset.totalhours || '0';
                AppState.elements.mainReports.style.display = 'none';
                AppState.elements.previewSection.style.display = 'block';
            },

            init() {
                document.querySelectorAll('.preview-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.preventDefault();
                        this.showPreview(e.currentTarget.closest('.report-card'));
                    });
                });
            }
        };

        function init() {
            FilterManager.init();
            StudentManager.init();

            AppState.elements.backBtn.addEventListener('click', () => {
                AppState.elements.previewSection.style.display = 'none';
                AppState.elements.mainReports.style.display = 'block';
                AppState.currentStudentId = null;
            });

            AppState.elements.downloadTemplateBtn.addEventListener('click', (e) => {
                e.preventDefault();
                if (!AppState.currentStudentId) {
                    Utils.showToast('Please select a student first', 'error');
                    return;
                }
                const { student, card } = Utils.getStudentInfo(AppState.currentStudentId);
                let csv = "TASK TEMPLATE\n" + "=".repeat(50) + "\n\n";
                csv += "Generated for:," + (student?.fullName || card?.dataset.name || 'Student') + "\n";
                csv += "Student ID:," + (student?.studentId || card?.dataset.studentid || 'N/A') + "\n";
                csv += "Program:," + (student?.program || card?.dataset.course || 'N/A') + "\n";
                csv += "Date:," + new Date().toLocaleDateString() + "\n\n";
                csv += "TASK TEMPLATE - INSTRUCTIONS\nPlease fill in the following information:\n\n";
                csv += "Task Name,Description,Due Date,Status,Remarks\n";
                csv += "Sample Task 1,Enter task description here,YYYY-MM-DD,Pending,\n";
                csv += "Sample Task 2,Enter task description here,YYYY-MM-DD,Pending,\n";
                csv += "Sample Task 3,Enter task description here,YYYY-MM-DD,Pending,\n";

                const studentName = (student?.fullName || card?.dataset.name || 'Student').replace(/\s+/g, '_');
                const fileName = `Task_Template_${studentName}_${new Date().toISOString().split('T')[0]}.csv`;
                const blob = new Blob(["\uFEFF" + csv], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = fileName;
                link.click();
                URL.revokeObjectURL(url);
                Utils.showToast('Task template downloaded', 'success');
            });

            AppState.elements.downloadDocumentsBtn.addEventListener('click', () => DocumentManager.downloadSelected());
            AppState.elements.downloadTimeLogsBtn.addEventListener('click', () => TimeLogManager.downloadSelected?.());

            console.log('Application initialized successfully');
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
</script>