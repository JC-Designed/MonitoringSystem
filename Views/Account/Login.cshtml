@model MonitoringSystem.Models.ParamModel.LoginParamModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-card">
    <div class="logo-container">
        <img src="~/images/ctu-logo.png" alt="CTU Logo" />
    </div>

    <div class="divider"></div>

    <!-- LOGIN FORM (visible by default) -->
    <div class="form-side" id="loginFormContainer">
        <h4>Login to your account</h4>

        <form id="loginForm">
            <!-- EMAIL -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" id="textEmail" name="Email" placeholder="Enter your email" required />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" id="textPassword" name="Password" class="form-control" placeholder="Enter your password" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- REMEMBER ME -->
            <div class="form-check mb-3">
                <input type="checkbox" id="remember" name="RememberMe" class="form-check-input" />
                <label for="remember" class="form-check-label">Remember me</label>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn-ctu mb-3 w-100">Sign In</button>

            <!-- REGISTER & FORGOT PASSWORD LINKS -->
            <div class="d-flex justify-content-between align-items-center">
                <small>Don't have an account? <a asp-action="Register">Sign Up</a></small>
                <small><a href="#" id="forgotPasswordLink">Forgot password?</a></small>
            </div>

            <!-- ERROR MESSAGE -->
            <div id="loginError" class="alert alert-danger mt-3 text-center" style="display:none;"></div>
            <!-- DEBUG INFO (will be hidden by default) -->
            <div id="debugInfo" class="alert alert-info mt-3 text-center small" style="display:none;"></div>
        </form>
    </div>

    <!-- FORGOT PASSWORD FORM (hidden initially) -->
    <div class="form-side" id="forgotPasswordContainer" style="display:none;">
        <h4>Reset Password</h4>
        <p class="text-muted small">Enter your email address and we'll send you a link to reset your password.</p>

        <form id="forgotPasswordForm">
            <!-- EMAIL -->
            <div class="mb-4">
                <label class="form-label">Email address</label>
                <input type="email" class="form-control" id="emailForgot" name="Email" placeholder="your@email.com" required />
            </div>

            <!-- ACTION BUTTONS -->
            <div class="d-flex justify-content-between align-items-center">
                <small>
                    <a href="#" id="backToLoginLink">← Back to login</a>
                </small>
                <button type="submit" class="btn btn-primary">Reset password</button>
            </div>

            <!-- FORGOT PASSWORD ERROR/SUCCESS MESSAGE -->
            <div id="forgotPasswordMessage" class="alert mt-3 text-center" style="display:none;"></div>
        </form>
    </div>
</div>

<!-- E-SIGNATURE REQUIRED MODAL -->
<div class="modal fade" id="esignModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">e-Signature Required</h5>
            </div>
            <div class="modal-body text-center">
                <p>Please provide an e-signature first before accessing the system.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" id="proceedEsign">Proceed</button>
            </div>
        </div>
    </div>
</div>

<script>
    // --- Toggle between Login and Forgot Password forms ---
    const loginContainer = document.getElementById('loginFormContainer');
    const forgotContainer = document.getElementById('forgotPasswordContainer');
    const forgotLink = document.getElementById('forgotPasswordLink');
    const backToLoginLink = document.getElementById('backToLoginLink');

    forgotLink.addEventListener('click', function(e) {
        e.preventDefault();
        loginContainer.style.display = 'none';
        forgotContainer.style.display = 'block';
    });

    backToLoginLink.addEventListener('click', function(e) {
        e.preventDefault();
        forgotContainer.style.display = 'none';
        loginContainer.style.display = 'block';
        document.getElementById('forgotPasswordMessage').style.display = 'none';
    });

    // --- Login form submission ---
    document.getElementById("loginForm").addEventListener("submit", async function(event) {
        event.preventDefault();

        var email = document.getElementById('textEmail').value.trim();
        var password = document.getElementById('textPassword').value.trim();
        var rememberMe = document.getElementById('remember').checked;

        console.log("========== LOGIN ATTEMPT ==========");
        console.log("Email:", email);
        console.log("Password length:", password.length);
        console.log("Remember Me:", rememberMe);

        // Show loading state
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Signing in...';
        submitBtn.disabled = true;

        // Hide any previous errors
        const errorDiv = document.getElementById('loginError');
        const debugDiv = document.getElementById('debugInfo');
        errorDiv.style.display = 'none';
        debugDiv.style.display = 'none';

        try {
            console.log("Sending request to /Account/LoginCredentials");

            const requestBody = {
                Username: email,
                Password: password,
                RememberMe: rememberMe
            };

            console.log("Request body:", JSON.stringify(requestBody));

            const res = await fetch('/Account/LoginCredentials', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(requestBody)
            });

            console.log("Response status:", res.status);
            console.log("Response status text:", res.statusText);
            console.log("Response headers:", [...res.headers.entries()]);

            // Try to get the response text first
            const responseText = await res.text();
            console.log("Raw response text:", responseText);

            // Try to parse as JSON
            let data;
            try {
                data = JSON.parse(responseText);
                console.log("Parsed JSON data:", data);
            } catch (parseError) {
                console.error("Failed to parse response as JSON:", parseError);
                console.error("Response was:", responseText);

                // Show the raw response for debugging
                debugDiv.style.display = 'block';
                debugDiv.innerHTML = `<strong>Server returned non-JSON response:</strong><br>${responseText.substring(0, 200)}`;

                errorDiv.style.display = 'block';
                errorDiv.textContent = "Server error. Please check console for details.";

                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
                return;
            }

            if (data.success) {
                console.log("Login successful, redirecting to:", data.redirect);

                // Check if e-signature is required for company
                if (data.hasESign === false && data.role === "Company") {
                    var modal = new bootstrap.Modal(document.getElementById('esignModal'));
                    modal.show();
                } else {
                    window.location.href = data.redirect;
                }
            } else {
                console.log("Login failed:", data.message);
                errorDiv.style.display = 'block';
                errorDiv.textContent = data.message || "Login failed. Please try again.";

                submitBtn.textContent = originalText;
                submitBtn.disabled = false;
            }
        } catch (err) {
            console.error("========== FETCH ERROR ==========");
            console.error("Error name:", err.name);
            console.error("Error message:", err.message);
            console.error("Error stack:", err.stack);
            console.error("=================================");

            errorDiv.style.display = 'block';
            errorDiv.textContent = "Network error: " + err.message;

            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
        }
    });

    // --- Forgot Password form submission ---
    document.getElementById("forgotPasswordForm").addEventListener("submit", async function(e) {
        e.preventDefault();
        const email = document.getElementById('emailForgot').value.trim();
        const messageDiv = document.getElementById('forgotPasswordMessage');

        if (!email) {
            messageDiv.style.display = 'block';
            messageDiv.className = 'alert alert-danger mt-3 text-center';
            messageDiv.textContent = 'Please enter your email address.';
            return;
        }

        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Sending...';
        submitBtn.disabled = true;

        try {
            const res = await fetch('/Account/ForgotPassword', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ Email: email })
            });

            const responseText = await res.text();
            let data;
            try {
                data = JSON.parse(responseText);
            } catch (e) {
                console.error("Forgot password response not JSON:", responseText);
                data = { success: false, message: "Server error" };
            }

            messageDiv.style.display = 'block';
            if (data.success) {
                messageDiv.className = 'alert alert-success mt-3 text-center';
                messageDiv.textContent = data.message || 'Reset link sent to your email.';
                document.getElementById('emailForgot').value = '';
            } else {
                messageDiv.className = 'alert alert-danger mt-3 text-center';
                messageDiv.textContent = data.message || 'An error occurred. Please try again.';
            }
        } catch (err) {
            console.error(err);
            messageDiv.style.display = 'block';
            messageDiv.className = 'alert alert-danger mt-3 text-center';
            messageDiv.textContent = 'Network error. Please try again later.';
        } finally {
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
        }
    });

    // --- Proceed to e-signature ---
    document.getElementById("proceedEsign").addEventListener("click", function() {
        window.location.href = "/Company/ESign";
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}