@model MonitoringSystem.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-card">
    <div class="logo-container">
        <img src="~/images/ctu-logo.png" alt="CTU Logo" />
    </div>

    <div class="divider"></div>

    <div class="form-side">
        <h4>Login to your account</h4>

        <form>
            <!-- USERNAME -->
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input class="form-control" id="textUsername" placeholder="Email" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" id="textPassword" class="form-control" placeholder="Password" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- REMEMBER ME -->
            <div class="form-check mb-3">
                <input type="checkbox" id="remember" class="form-check-input" />
                <label for="remember" class="form-check-label">Remember me</label>
            </div>

            <!-- BUTTON -->
            <button type="submit" id="btnSubmit" class="btn-ctu mb-3 w-100">Sign In</button>

            <!-- REGISTER LINK -->
            <div class="text-center">
                <small>Don’t have an account? <a asp-action="Register">Sign Up</a></small>
            </div>

            <!-- ERROR MESSAGE -->
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3 text-center">@ViewBag.Error</div>
            }
        </form>
    </div>
</div>

<!-- E-SIGNATURE REQUIRED MODAL -->
<div class="modal fade" id="esignModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">e-Signature Required</h5>
            </div>
            <div class="modal-body text-center">
                <p>Please provide an e-signature first before accessing the system.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" id="proceedEsign">Proceed</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById("btnSubmit").addEventListener("click", function(event) {
        event.preventDefault();

        var username = document.getElementById('textUsername').value;
        var password = document.getElementById('textPassword').value;
        var rememberMe = document.getElementById('remember').checked;

        // ===== DEMO LOGIN SIMULATION =====
        // This replaces the real fetch call for demo purposes
        if (username === "demo@company.com" && password === "Demo@123") {
            var data = {
                success: true,
                role: "Company",
                hasESign: false, // simulate first-time login
                redirect: "/CompanyPanel/Dashboard"
            };


            if (data.role === "Company" && !data.hasESign) {
                var modal = new bootstrap.Modal(document.getElementById('esignModal'));
                modal.show();
            } else {
                window.location.href = data.redirect;
            }
        } else {
            // Keep your original fetch call for real login
            fetch('/Account/LoginCredentials', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    Username: username,
                    Password: password,
                    RememberMe: rememberMe
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    window.location.href = data.redirect;
                } else {
                    alert('Login failed: ' + data.message);
                }
            });
        }
    });

    // Redirect to e-sign page when Proceed is clicked
    document.getElementById("proceedEsign").addEventListener("click", function() {
        window.location.href = "/Company/ESign"; // you can create a demo ESign page
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}