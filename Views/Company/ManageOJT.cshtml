@{
    Layout = "_CompanyLayout";
    ViewData["Title"] = "Manage Interns";
}

<!-- Add Anti-Forgery Token -->
<input type="hidden" id="__RequestVerificationToken" value="@ViewData["RequestVerificationToken"]" />

<div class="container-fluid my-4" id="manageInternContainer">

    <!-- Filters and Search Row -->
    <div class="row mb-3 align-items-center">
        <div class="col-md-3">
            <label for="yearFilter" class="form-label">Academic Year</label>
            <select id="yearFilter" class="form-select">
                <option value="All" selected>All Years</option>
                <option value="2026">2026</option>
                <option value="2025">2025</option>
                <option value="2024">2024</option>
            </select>
        </div>

        <div class="col-md-3">
            <label for="searchName" class="form-label">Search by Name</label>
            <input type="text" id="searchName" class="form-control" placeholder="Type name...">
        </div>

        <div class="col-md-3">
            <button class="btn btn-primary" id="refreshBtn">
                <i class="bi bi-arrow-repeat"></i> Refresh
            </button>
        </div>

        <div class="col-md-3 text-end">
            <span id="traineeCount" class="badge bg-info fs-6 p-2">0 Trainees</span>
        </div>
    </div>

    <!-- Intern Table -->
    <div class="card shadow-sm p-4">
        <div class="table-responsive">
            <table class="table table-striped" id="internTable">
                <thead>
                    <tr>
                        <th>Student ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Program</th>
                        <th>Year</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="internTableBody">
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-people fs-1 d-block mb-2"></i>
                            Loading interns...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Student Profile Container -->
<div class="container-fluid my-4 position-relative" id="studentProfileContainer" style="display:none;">
    <img id="previewProfilePic" src="/images/defaultpicture.jpg" class="rounded-circle shadow position-absolute" style="width:150px;height:150px;object-fit:cover;border:4px solid white; top:20px; left:20px; z-index:10;" onerror="this.src='/images/defaultpicture.jpg';">
    <div style="height:190px;"></div>
    <div class="card shadow-sm p-4" style="max-width:1700px; width:97%; margin:auto; overflow:hidden;">
        <h5 class="fw-bold border-bottom pb-2 mb-3">Student Information</h5>
        <div class="row g-3">
            <div class="col-md-6"><strong>Name:</strong> <span id="pName"></span></div>
            <div class="col-md-6"><strong>Student ID:</strong> <span id="pStudentID"></span></div>
            <div class="col-md-6"><strong>Course:</strong> <span id="pCourse"></span></div>
            <div class="col-md-6"><strong>Year:</strong> <span id="pYear"></span></div>
            <div class="col-md-6"><strong>Facebook:</strong> <a id="pFacebook" href="#" target="_blank"></a></div>
            <div class="col-md-6"><strong>Mobile Number:</strong> <span id="pMobileNumber"></span></div>
            <div class="col-md-6"><strong>Address:</strong> <span id="pAddress"></span></div>
            <div class="col-md-6"><strong>Contact Person:</strong> <span id="pContactPerson"></span></div>
            <div class="col-md-6"><strong>Birthdate:</strong> <span id="pBirthdate"></span></div>
            <div class="col-md-6"><strong>Email:</strong> <span id="pEmail"></span></div>
            <div class="col-md-6"><strong>Status:</strong> <span id="pStatus"></span></div>
        </div>
        <button id="backBtn" class="position-absolute bottom-0 end-0 m-4 btn" style="background-color:#0787FF; color:white; border:none;">Back to List</button>
    </div>
</div>

<!-- REPORT MODAL -->
<div class="modal fade" id="reportModal" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reportModalLabel">Create Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label"><strong>Complainee:</strong></label>
                    <span id="complaineeName" class="fw-bold"></span>
                    <input type="hidden" id="complaineeId" />
                </div>
                <div class="mb-3">
                    <label for="incidentText" class="form-label"><strong>Incident:</strong></label>
                    <textarea id="incidentText" class="form-control" rows="8" placeholder="Describe the incident here..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="createReportBtn" class="btn" style="background-color:#02B508; color:white;">Create</button>
            </div>
        </div>
    </div>
</div>

<!-- TERMINATE MODAL -->
<div class="modal fade" id="terminateModal" tabindex="-1" aria-labelledby="terminateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="background-color:#8B0000; color:white;">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="terminateModalLabel">Terminate Student</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="terminateMessage" class="fs-4 fw-bold text-center"></p>
                <input type="hidden" id="terminateStudentId" />
                <div class="mb-3">
                    <label for="terminateRemarks" class="form-label"><strong>Remarks:</strong></label>
                    <textarea id="terminateRemarks" class="form-control" rows="5" placeholder="Reason for termination..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" id="confirmTerminateBtn" class="btn" style="background-color:#02B508; color:white;">Yes</button>
                <button type="button" class="btn" style="background-color:#FD0606; color:white;" data-bs-dismiss="modal">No</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Global variables
        let currentStudentData = null;
        const manageContainer = document.getElementById('manageInternContainer');
        const profileContainer = document.getElementById('studentProfileContainer');
        const internTableBody = document.getElementById('internTableBody');
        const yearFilter = document.getElementById('yearFilter');
        const searchInput = document.getElementById('searchName');
        const refreshBtn = document.getElementById('refreshBtn');
        const traineeCountSpan = document.getElementById('traineeCount');

        // ===== LOAD TRAINEES FROM DATABASE =====
        async function loadTrainees() {
            try {
                internTableBody.innerHTML = '<tr><td colspan="6" class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2">Loading interns...</p></td></tr>';

                const response = await fetch('/Company/GetTrainees', {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const result = await response.json();

                if (result.success && result.data && result.data.length > 0) {
                    displayTrainees(result.data);
                    traineeCountSpan.textContent = result.data.length + ' Trainees';
                } else {
                    internTableBody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-people fs-1 d-block mb-2"></i>No interns assigned yet</td></tr>';
                    traineeCountSpan.textContent = '0 Trainees';
                }
            } catch (error) {
                console.error('Error loading trainees:', error);
                internTableBody.innerHTML = '<tr><td colspan="6" class="text-center text-danger py-4"><i class="bi bi-exclamation-triangle fs-1 d-block mb-2"></i>Error loading interns</td></tr>';
                traineeCountSpan.textContent = 'Error';
            }
        }

        // ===== DISPLAY TRAINEES IN TABLE =====
        function displayTrainees(trainees) {
            let html = '';
            trainees.forEach(student => {
                html += `<tr data-id="${student.id}"
                            data-studentid="${escapeHtml(student.studentId) || ''}"
                            data-year="${student.year || '2026'}"
                            data-facebook="${escapeHtml(student.facebook) || ''}"
                            data-mobile="${escapeHtml(student.mobileNumber) || ''}"
                            data-address="${escapeHtml(student.address) || ''}"
                            data-contact="${escapeHtml(student.contactPerson) || ''}"
                            data-birthdate="${student.birthDate || ''}"
                            data-program="${escapeHtml(student.program) || ''}"
                            data-status="${escapeHtml(student.status) || 'Active'}">
                            <td>${escapeHtml(student.studentId) || 'N/A'}</td>
                            <td>${escapeHtml(student.fullName) || 'N/A'}</td>
                            <td>${escapeHtml(student.email) || 'N/A'}</td>
                            <td>${escapeHtml(student.program) || 'N/A'}</td>
                            <td>${student.year || 'N/A'}</td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        Actions
                                    </button>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item viewBtn" href="#">View Profile</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item reportBtn" href="#">Report Incident</a></li>
                                        <li><a class="dropdown-item text-danger terminateBtn" href="#">Terminate</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>`;
            });
            internTableBody.innerHTML = html;

            // Re-attach event listeners
            attachEventListeners();
            filterTable();
        }

        // Helper function to escape HTML
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ===== ATTACH EVENT LISTENERS =====
        function attachEventListeners() {
            // View Profile
            document.querySelectorAll('.viewBtn').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    e.preventDefault();
                    const row = e.target.closest('tr');
                    if (!row) return;

                    const studentId = row.dataset.id;

                    // Fetch full student details
                    try {
                        const response = await fetch(`/Company/GetTraineeDetails?studentId=${studentId}`);
                        const result = await response.json();

                        if (result.success && result.data) {
                            const student = result.data;
                            document.getElementById('pName').textContent = student.fullName || 'N/A';
                            document.getElementById('pStudentID').textContent = student.studentId || 'N/A';
                            document.getElementById('pCourse').textContent = student.program || 'N/A';
                            document.getElementById('pYear').textContent = student.year || 'N/A';
                            document.getElementById('pFacebook').textContent = student.facebook || 'Not provided';
                            document.getElementById('pFacebook').href = student.facebook || '#';
                            document.getElementById('pMobileNumber').textContent = student.mobileNumber || 'Not provided';
                            document.getElementById('pAddress').textContent = student.address || 'Not provided';
                            document.getElementById('pContactPerson').textContent = student.contactPerson || 'Not provided';
                            document.getElementById('pBirthdate').textContent = student.birthDate || 'Not provided';
                            document.getElementById('pEmail').textContent = student.email || 'N/A';
                            document.getElementById('pStatus').textContent = row.dataset.status || 'Active';
                            document.getElementById('previewProfilePic').src = '/images/defaultpicture.jpg';

                            manageContainer.style.display = 'none';
                            profileContainer.style.display = 'block';
                        } else {
                            alert('Error loading student details');
                        }
                    } catch (error) {
                        console.error('Error fetching student details:', error);
                        alert('Error loading student details');
                    }
                });
            });

            // Report
            document.querySelectorAll('.reportBtn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const row = e.target.closest('tr');
                    const studentName = row.cells[1].textContent;
                    const studentId = row.dataset.id;

                    document.getElementById('complaineeName').textContent = studentName;
                    document.getElementById('complaineeId').value = studentId;
                    document.getElementById('incidentText').value = '';
                    reportModal.show();
                });
            });

            // Terminate
            document.querySelectorAll('.terminateBtn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const row = e.target.closest('tr');
                    const studentName = row.cells[1].textContent;
                    const studentId = row.dataset.id;

                    document.getElementById('terminateMessage').textContent = `Are you sure you want to terminate ${studentName}?`;
                    document.getElementById('terminateStudentId').value = studentId;
                    document.getElementById('terminateRemarks').value = '';
                    terminateModal.show();
                });
            });
        }

        // ===== FILTER AND SEARCH =====
        function filterTable() {
            const selectedYear = yearFilter.value;
            const searchText = searchInput.value.toLowerCase();
            const rows = document.querySelectorAll('#internTable tbody tr');

            let visibleCount = 0;
            rows.forEach(row => {
                if (row.children.length === 1) return;
                const name = row.cells[1].textContent.toLowerCase();
                const rowYear = row.dataset.year;
                const shouldShow = (selectedYear === 'All' || rowYear === selectedYear) && name.includes(searchText);
                row.style.display = shouldShow ? '' : 'none';
                if (shouldShow) visibleCount++;
            });

            // Update visible count
            if (visibleCount > 0) {
                traineeCountSpan.textContent = visibleCount + ' Trainees (Filtered)';
            } else {
                const totalRows = document.querySelectorAll('#internTable tbody tr:not([style*="display: none"])').length;
                if (totalRows === 0 && rows.length > 0) {
                    traineeCountSpan.textContent = '0 Trainees';
                }
            }
        }

        // ===== BACK BUTTON =====
        document.getElementById('backBtn').addEventListener('click', () => {
            profileContainer.style.display = 'none';
            manageContainer.style.display = 'block';
            loadTrainees(); // Refresh list when coming back
        });

        // ===== REPORT MODAL =====
        const reportModal = new bootstrap.Modal(document.getElementById('reportModal'));
        const incidentText = document.getElementById('incidentText');
        const createReportBtn = document.getElementById('createReportBtn');

        createReportBtn.addEventListener('click', async () => {
            const studentId = document.getElementById('complaineeId').value;
            const incident = incidentText.value.trim();

            if (!incident) {
                alert('Please describe the incident');
                return;
            }

            try {
                const token = document.getElementById('__RequestVerificationToken')?.value;

                const response = await fetch('/Company/CreateReport', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        studentId: studentId,
                        incident: incident
                    })
                });

                const result = await response.json();

                if (result.success) {
                    alert('Report has been created successfully!');
                    reportModal.hide();
                    incidentText.value = '';
                } else {
                    alert('Error creating report: ' + (result.message || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error creating report:', error);
                alert('An error occurred while creating the report');
            }
        });

        // ===== TERMINATE MODAL =====
        const terminateModal = new bootstrap.Modal(document.getElementById('terminateModal'));
        const terminateRemarks = document.getElementById('terminateRemarks');
        const confirmTerminateBtn = document.getElementById('confirmTerminateBtn');

        confirmTerminateBtn.onclick = async () => {
            const studentId = document.getElementById('terminateStudentId').value;
            const studentName = document.getElementById('terminateMessage').textContent.replace('Are you sure you want to terminate ', '').replace('?', '');
            const remarks = terminateRemarks.value;

            try {
                const token = document.getElementById('__RequestVerificationToken')?.value;

                const response = await fetch('/Company/TerminateTrainee', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        studentId: studentId,
                        remarks: remarks
                    })
                });

                const result = await response.json();

                if (result.success) {
                    alert(`${studentName} has been terminated!`);
                    terminateModal.hide();
                    loadTrainees(); // Refresh the list
                } else {
                    alert('Error terminating student: ' + (result.message || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error terminating student:', error);
                alert('An error occurred while terminating the student');
            }
        };

        // ===== REFRESH BUTTON =====
        refreshBtn.addEventListener('click', loadTrainees);

        // ===== EVENT LISTENERS FOR FILTERS =====
        yearFilter.addEventListener('change', filterTable);
        searchInput.addEventListener('input', filterTable);

        // ===== INITIAL LOAD =====
        document.addEventListener('DOMContentLoaded', loadTrainees);
    </script>
}