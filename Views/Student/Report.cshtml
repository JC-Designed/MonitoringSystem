@model List<MonitoringSystem.Models.StudentTask>

@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Report";
    // Fix: Create a local variable to handle null Model
    var reportList = Model ?? new List<MonitoringSystem.Models.StudentTask>();
}

<div class="container-fluid p-0 m-0" style="background: transparent;">
    <div class="card shadow-sm rounded-4 p-4 m-3" style="overflow: visible; background: white;">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <button class="btn btn-primary" id="createReportBtn" data-bs-toggle="modal" data-bs-target="#createReportModal">
                    Create Report
                </button>
            </div>
        </div>

        <div class="row g-3 mb-4 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Search by Task</label>
                <input type="text" id="reportSearchInput" class="form-control" placeholder="Type task title..." />
            </div>
        </div>

        <div class="table-responsive" style="overflow: visible;">
            <table class="table table-hover align-middle mb-0" id="reportTable">
                <thead class="table-light">
                    <tr>
                        <th class="py-3">Document Type</th>
                        <th class="py-3">Date Uploaded</th>
                        <th class="py-3 text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (reportList.Any())
                    {
                        foreach (var task in reportList)
                        {
                            <tr data-id="@task.Id" data-title="@task.Title" data-datefrom="@task.DateFrom.ToString("yyyy-MM-dd")">
                                <td class="py-3">@task.Title</td>
                                <td class="py-3">@task.DateFrom.ToString("yyyy-MM-dd")</td>
                                <td class="text-center py-3">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown"></button>
                                        <ul class="dropdown-menu shadow" style="z-index:9999;">
                                            <li><a class="dropdown-item edit-report" href="#">Edit</a></li>
                                            <li><a class="dropdown-item text-danger" href="/Student/Delete/@task.Id">Delete</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td class="py-3">Sample Report</td>
                            <td class="py-3">2026-02-26</td>
                            <td class="text-center py-3">
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown"></button>
                                    <ul class="dropdown-menu shadow" style="z-index:9999;">
                                        <li><a class="dropdown-item edit-report" href="#">Edit</a></li>
                                        <li><a class="dropdown-item text-danger" href="#">Delete</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- CREATE REPORT MODAL -->
<div class="modal fade" id="createReportModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content p-4 rounded-4">

            <div class="modal-header">
                <h5 id="modalTitle">Create Report</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="CreateReport" asp-controller="Student" method="post" id="reportForm">
                <input type="hidden" name="Id" id="reportId" />
                <div class="modal-body">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label>Report Type</label>
                            <input type="text" name="Title" id="reportTitle" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label>Date Uploaded</label>
                            <input type="date" name="DateFrom" id="reportDateFrom" class="form-control" required />
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn text-white" style="background-color:#FE5252;" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn text-white" style="background-color:#02B508;" id="modalSubmitBtn">Create</button>
                </div>
            </form>

        </div>
    </div>
</div>

<style>
    /* Remove all padding and margins from container */
    .container-fluid {
        padding: 0 !important;
        margin: 0 !important;
        background: transparent !important;
    }

    /* Ensure the top bar/navbar is visible */
    .navbar, .top-bar, header {
        position: relative;
        z-index: 1000;
    }

    /* Card styling with proper margins */
    .card {
        margin: 15px !important;
        background: white !important;
        border: none !important;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    /* Remove any extra spacing from the row */
    .row {
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    /* Dropdown styling */
    .dropdown-menu {
        z-index: 9999;
    }

    /* Table hover effect */
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05);
    }

    /* Ensure no white background on body */
    body {
        background: #f0f2f5 !important;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const modal = new bootstrap.Modal(document.getElementById("createReportModal"));
        const modalTitle = document.getElementById("modalTitle");
        const modalSubmitBtn = document.getElementById("modalSubmitBtn");
        const reportId = document.getElementById("reportId");
        const reportTitle = document.getElementById("reportTitle");
        const reportDateFrom = document.getElementById("reportDateFrom");

        // Open modal for Create
        document.getElementById("createReportBtn").addEventListener("click", () => {
            modalTitle.textContent = "Create Report";
            modalSubmitBtn.textContent = "Create";
            reportId.value = "";
            reportTitle.value = "";
            reportDateFrom.value = "";
            modal.show();
        });

        // Open modal for Edit
        document.querySelectorAll(".edit-report").forEach(btn => {
            btn.addEventListener("click", function (e) {
                e.preventDefault();
                const row = e.target.closest("tr");
                modalTitle.textContent = "Edit Report";
                modalSubmitBtn.textContent = "Update";
                reportId.value = row.dataset.id;
                reportTitle.value = row.dataset.title;
                reportDateFrom.value = row.dataset.datefrom;
                modal.show();
            });
        });

        // Search
        document.getElementById("reportSearchInput").addEventListener("input", function () {
            let value = this.value.toLowerCase();
            document.querySelectorAll("#reportTable tbody tr").forEach(row => {
                row.style.display = row.dataset.title?.toLowerCase().includes(value) ? "" : "none";
            });
        });

    });
</script>